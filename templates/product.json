          "type": "custom-liquid",
          "disabled": true,
          "settings": {
            "custom_liquid": "{% if product.tags contains \"Option: Painted\" %}\n<p><b>PREMIUM PAINT JOB:</b> 1 coat of primer, 2 coats of color, and 2 coats of clear. Partify paints just like the factory does. 97%-99% color match guaranteed.  </p><p>\n  {% endif %}"
