        "36419bf2-c0eb-45fa-8ebc-68487c89820c": {
          "type": "custom-liquid",
          "settings": {
            "custom_liquid": "{% if product.tags contains \"Economy/Premium\" %}<p>\nAt checkout you will be presented with two different shipping options.</p>\n<p><b>STANDARD SHIPPING:</b> Your bumper will be folded for the most inexpensive shipping possible. This method can cause imperfections.</p>\n<p><b>PREMIUM SHIPPING:</b> Your bumper will come unfolded. Guaranteed to arrive with no damage.</p>\n  {% endif %}"
          }
        },
        "custom_liquid_MwatAr": {
          "type": "custom-liquid",
          "settings": {
            "custom_liquid": "{% if product.tags contains \"Economy/Freight\" %}<p>\nAt checkout you will be presented with two different shipping options.</p>\n<p><b>STANDARD SHIPPING:</b> Your bumper will be folded for the most inexpensive shipping possible. This method can cause imperfections.</p>\n<p><b>FREIGHT SHIPPING:</b> Your bumper will come unfolded. Guaranteed to arrive with no damage.</p>\n  {% endif %}"
