<script>
  document.addEventListener('DOMContentLoaded', () => {
    const businessFormWrapper = document.querySelector('.business-form-wrapper');
    const form = document.querySelector('.ai-business-form-{{ ai_gen_id }} form');
    const basicForm = document.querySelector('.basic-business-form');
    const tailoredForm = document.querySelector('.tailored-business-form-{{ ai_gen_id }}');
    const continueButton = document.querySelector('.ai-business-form__continue-button');
    const previousButton = document.querySelector('.ai-business-form__previous-button-{{ ai_gen_id }}');
    const requiredFields = document.querySelectorAll('.basic-business-form [required]');
    const submitButton = form.querySelector('.ai-business-form__button-{{ ai_gen_id }}');
    const successMessage = document.querySelector('.business-form-submission-message');
    const proceedToCheckoutBtn = document.querySelector('.ai-business-form__checkout-button-{{ ai_gen_id }}');


    requiredFields.forEach(field => {
      field.addEventListener('input', validateForm);
      field.addEventListener('change', validateForm);
    });

    // Initial validation on page load
    validateForm();


    if (form) {
      form.addEventListener('submit', async function (event) {
         event.preventDefault();

         console.log('wool is submitting the form');
         submitButton.disabled = true;
         submitButton.classList.add('ai-business-form__button--loading');
         submitButton.textContent = '';

        let isValid = true;
        const visibleInputs = form.querySelectorAll(
          '.state-question:not([style*="display: none"]) input[required], .state-question:not([style*="display: none"]) select[required]'
        );

        visibleInputs.forEach((input) => {
          const errorElement = form.querySelector(
            `[data-field-error="${input.name.replace('contact[', '').replace(']', '')}"]`
          );

          if (!input.value.trim()) {
            isValid = false;
            input.setAttribute('aria-invalid', 'true');
            if (errorElement) errorElement.style.display = 'block';
          } else {
            input.removeAttribute('aria-invalid');
            if (errorElement) errorElement.style.display = 'none';
          }

          if (input.type === 'email' && input.value.trim() && !validateEmail(input.value)) {
            isValid = false;
            input.setAttribute('aria-invalid', 'true');
            if (errorElement) errorElement.style.display = 'block';
          }
        });

        if (!isValid) {
          return;
        }

        // ✨ Begin PDF logic after validation
        const formData = new FormData(form);
        const businessName = formData.get('contact[business_name]');
        const firstName = formData.get('contact[firstName]');
        const lastName = formData.get('contact[lastName]');
        const phoneNumber = formData.get('contact[phone]');
        const email = formData.get('contact[email]');
        const title = formData.get('contact[title]');
        const streetAddress = formData.get('contact[street_address]');
        const city = formData.get('contact[city]');
        const state = formData.get('contact[state]');
        const zipcode = formData.get('contact[zipcode]');
        const type = formData.get('contact[type]');
        const reason = formData.get('contact[reason]');
        const taxRegistrationId = formData.get('contact[id]');

        const typeSelect = document.getElementById(`Type-{{ ai_gen_id }}`);
        const reasonSelect = document.getElementById(`Reason-{{ ai_gen_id }}`);

        // Then, get the selected option text
        const typeText = typeSelect.options[typeSelect.selectedIndex].text;
        const reasonText = reasonSelect.options[reasonSelect.selectedIndex].text;

        console.log('type text:', typeText);
        console.log('reason text:', reasonText);

        console.log('type: ', type);
        console.log('reason: ', reason);


        try {
          const pdfUrl = 'https://cdn.shopify.com/s/files/1/0248/6291/6693/files/streamline-tax-exemption.pdf?v=1731952965';
          const examplePdfUrl = 'https://cdn.shopify.com/s/files/1/0248/6291/6693/files/Streamline_Form_Example.pdf?v=1748888393';
          {% comment %} const taxRegistrationId = '88-1231234'; {% endcomment %}
          const pdfBytes = await fetch(pdfUrl).then((res) => res.arrayBuffer());

          const { PDFDocument } = window.PDFLib;
          const pdfDoc = await PDFDocument.load(pdfBytes);
          const pdfForm = pdfDoc.getForm();
          const fields = pdfForm.getFields();

          createCompanyProfile(businessName, firstName, lastName, email, phoneNumber, title, streetAddress, city, zipcode, state, businessName, examplePdfUrl, taxRegistrationId, typeText, reasonText);

          {% comment %} fields.forEach((field) => {
            const name = field.getName();
            const type = field.constructor.name;
            console.log('Field type: ', type);

            if (type === 'e') {
              console.log(`--- Checkbox Group: ${name} ---`);

              // pdf-lib doesn't expose widget-level info directly,
              // but we can peek into the internal structure.
              const widgets = field.acroField.getWidgets();

              widgets.forEach((widget, index) => {
                const dict = widget.dict;
                const ap = dict.lookup(PDFLib.PDFName.of("AP")); // Appearance dictionary
                const n = ap?.lookup(PDFLib.PDFName.of("N"));     // Normal appearance

                if (n) {
                  const appearanceKeys = n.keys(); // all the possible ON values (like 'LLC', 'Corp')
                  for (const key of appearanceKeys) {
                    if (key !== PDFLib.PDFName.of("Off")) {
                      console.log(`  ➤ Widget [${index}] option: ${key.decodeText ? key.decodeText() : key}`);
                    }
                  }
                }

                // Is it currently checked?
                const currentValue = dict.get(PDFLib.PDFName.of('AS'));
                console.log(`  ↳ Widget [${index}] current value: ${currentValue?.decodeText?.() || currentValue?.name}`);
              });
            }
          });

          pdfForm.getTextField('Item.Your.Name').setText(contactName);
          pdfForm.getTextField('Item.BusinessAddress').setText(businessName);

          const typeField = pdfForm.getCheckBox('Item.Checkbox');
          console.log('typeField: ', typeField);

          const reasonField = pdfForm.getCheckBox('Item.Checkbox2');
          {% comment %} const reasonAppearances = reasonField.acroField.getOnValues(); {% endcomment %}
          {% comment %} console.log('reasonAppearances: ', reasonAppearances); {% endcomment %}

          // Optional: Set dropdowns if the PDF has them
          try {
            console.log('typeField: ', typeField);
            console.log('reasonField: ', reasonField);
            if (typeAppearances.includes(type)) {
              typeField.check(type);
            } else {
              typeField.uncheckAll();
            }
            if (reasonAppearances.includes(reason)) {
              reasonField.check(reason);
            } else {
              reasonField.uncheckAll();
            }
          } catch (err) {
            console.warn('Dropdown fields may not exist in the PDF');
          }

          pdfForm.flatten(); // prevent further editing

          const pdfBytesModified = await pdfDoc.save();

          // Download the filled PDF
          const blob = new Blob([pdfBytesModified], { type: 'application/pdf' });
          const link = document.createElement('a');
          link.href = URL.createObjectURL(blob);
          link.download = 'streamlined-exemption.pdf';
          document.body.appendChild(link);
          link.click();
          link.remove(); {% endcomment %}
          successMessage.style.display = 'flex';
          businessFormWrapper.style.display = 'none';
        } catch (err) {
          console.error('PDF generation/upload failed:', err);
        } finally {
          submitButton.disabled = false;
          submitButton.classList.remove('ai-business-form__button--loading');
          submitButton.textContent = 'Submit';
        }
      });
    }


    continueButton.addEventListener('click', function () {
      const stateCode = getStateFromURL();
      console.log('continue button clicked, state code: ', stateCode);
      updateFieldVisibilityBasedOnState(stateCode);

      basicForm.style.display = 'none';
      tailoredForm.style.display = 'block';
    });

    previousButton.addEventListener('click', function () {
      basicForm.style.display = 'flex';
      tailoredForm.style.display = 'none';
    });

    proceedToCheckoutBtn.addEventListener('click', function() {
      // Redirect to the checkout page
      window.location.href = '/checkout';
    });


    function validateForm() {
      let allValid = true;

      requiredFields.forEach(field => {
        // If it's an input/select and is invalid or empty, mark as not valid
        if (field.type === 'select-one') {
          if (field.value === '') {
            allValid = false;
          }
        } else if (!field.value.trim()) {
          allValid = false;
        } else if (!field.checkValidity()) {
          allValid = false;
        }
      });

      console.log('wool allValid: ', allValid);

      // Enable or disable the button based on validity
      continueButton.disabled = !allValid;
    }

    function getStateFromURL() {
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.has('state')) {
        return urlParams.get('state').toUpperCase();
      } else {
        return 'STREAMLINE'; // default fallback
      }
    }

    function updateFieldVisibilityBasedOnState(stateCode) {
      const allStateQuestions = document.querySelectorAll('.state-question');

      allStateQuestions.forEach((field) => {
        const showFor = field.getAttribute('data-show-for');
        const acceptedStates = showFor ? showFor.split(',').map((s) => s.trim().toUpperCase()) : [];
        console.log('wool acceptedStates: ', acceptedStates);

        if (acceptedStates.includes(stateCode)) {
          field.style.display = 'flex'; // or block, depending on your layout
          const requiredInput = field.querySelector('[required]');
          if (requiredInput) requiredInput.setAttribute('aria-required', 'true');
        } else {
          field.style.display = 'none';
          const input = field.querySelector('input, select, textarea');
          if (input) {
            input.removeAttribute('required');
            input.removeAttribute('aria-required');
            input.removeAttribute('aria-invalid');
            // Also hide any visible error
            const errorEl = field.querySelector('[data-field-error]');
            if (errorEl) errorEl.style.display = 'none';
          }
        }
      });
    }

    function validateEmail(email) {
      const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      return re.test(email);
    }
  });
</script>

