{% assign ai_gen_id = section.id | replace: '_', '' | downcase %}

{% style %}
  .ai-business-form-{{ ai_gen_id }} {
    max-width: 500px;
    margin: 0 auto;
    padding: 30px;
    background-color: {{ section.settings.background_color }};
    border-radius: {{ section.settings.border_radius }}px;
  }

  .ai-business-form__heading-{{ ai_gen_id }} {
    margin-top: 0;
    margin-bottom: 20px;
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.heading_size }}px;
    text-align: {{ section.settings.text_alignment }};
  }

  .ai-business-form__description-{{ ai_gen_id }} {
    margin-bottom: 25px;
    color: {{ section.settings.text_color }};
    text-align: {{ section.settings.text_alignment }};
  }

  .ai-business-form__fields-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-business-form__field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-business-form__label-{{ ai_gen_id }} {
    font-weight: 500;
    color: {{ section.settings.text_color }};
  }

  .ai-business-form__input-{{ ai_gen_id }},
  .ai-business-form__select-{{ ai_gen_id }} {
    padding: 12px 16px;
    border: 1px solid {{ section.settings.input_border_color }};
    border-radius: {{ section.settings.input_border_radius }}px;
    background-color: {{ section.settings.input_background_color }};
    color: {{ section.settings.text_color }};
  }

  .ai-business-form__button-{{ ai_gen_id }} {
    margin-top: 20px;
    padding: 14px 28px;
    background-color: {{ section.settings.button_color }};
    color: {{ section.settings.button_text_color}};
    border: none;
    border-radius: {{ section.settings.button_border_radius }}px;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.3s;
    align-self: {{ section.settings.button_alignment }};
  }

  .ai-business-form__button-{{ ai_gen_id }}:hover {
    background-color: {{ section.settings.button_hover_color }};
  }

  .ai-business-form__success-{{ ai_gen_id }} {
    margin-top: 20px;
    padding: 15px;
    background-color: {{ section.settings.success_color }};
    color: #ffffff;
    border-radius: 4px;
    display: none;
  }

  .ai-business-form__error-{{ ai_gen_id }} {
    margin-top: 20px;
    padding: 15px;
    background-color: {{ section.settings.error_color }};
    color: #ffffff;
    border-radius: 4px;
    display: none;
  }

  .ai-business-form__field-error-{{ ai_gen_id }} {
    color: {{ section.settings.text_color }};
    font-size: 14px;
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-business-form-{{ ai_gen_id }} {
      padding: 20px;
    }

    .ai-business-form__button-{{ ai_gen_id }} {
      width: 100%;
      align-self: stretch;
    }
  }
{% endstyle %}

<div class="ai-business-form-{{ ai_gen_id }}" {{ section.shopify_attributes }}>
  {% if section.settings.heading != blank %}
    <h2 class="ai-business-form__heading-{{ ai_gen_id }}">{{ section.settings.heading }}</h2>
  {% endif %}

  {% if section.settings.description != blank %}
    <div class="ai-business-form__description-{{ ai_gen_id }}">{{ section.settings.description }}</div>
  {% endif %}

  {%- form 'contact', id: 'streamlineForm' -%}
    <div class="ai-business-form__fields-{{ ai_gen_id }}">
      <div
        class="ai-business-form__field-{{ ai_gen_id }} state-question"
        data-show-for="STREAMLINE"
        style="display: none;"
      >
        <label for="BusinessName-{{ ai_gen_id }}" class="ai-business-form__label-{{ ai_gen_id }}">
          {{ section.settings.business_name_label }}
          <span aria-hidden="true">*</span>
        </label>
        <input
          type="text"
          id="BusinessName-{{ ai_gen_id }}"
          name="contact[business_name]"
          class="ai-business-form__input-{{ ai_gen_id }}"
          required
          aria-required="true"
        >
        <span class="ai-business-form__field-error-{{ ai_gen_id }}" data-field-error="business_name">
          Please enter your business name
        </span>
      </div>

      <div
        class="ai-business-form__field-{{ ai_gen_id }} state-question"
        data-show-for="STREAMLINE"
        style="display: none;"
      >
        <label for="ContactName-{{ ai_gen_id }}" class="ai-business-form__label-{{ ai_gen_id }}">
          {{ section.settings.contact_name_label }}
          <span aria-hidden="true">*</span>
        </label>
        <input
          type="text"
          id="ContactName-{{ ai_gen_id }}"
          name="contact[name]"
          class="ai-business-form__input-{{ ai_gen_id }}"
          required
          aria-required="true"
        >
        <span class="ai-business-form__field-error-{{ ai_gen_id }}" data-field-error="contact_name">
          Please enter your name
        </span>
      </div>

      <div
        class="ai-business-form__field-{{ ai_gen_id }} state-question"
        data-show-for="STREAMLINE"
        style="display: none;"
      >
        <label for="Email-{{ ai_gen_id }}" class="ai-business-form__label-{{ ai_gen_id }}">
          {{ section.settings.email_label }}
          <span aria-hidden="true">*</span>
        </label>
        <input
          type="email"
          id="Email-{{ ai_gen_id }}"
          name="contact[email]"
          class="ai-business-form__input-{{ ai_gen_id }}"
          required
          aria-required="true"
          autocorrect="off"
          autocapitalize="off"
          autocomplete="email"
        >
        <span class="ai-business-form__field-error-{{ ai_gen_id }}" data-field-error="email">
          Please enter a valid email address
        </span>
      </div>

      <div
        class="ai-business-form__field-{{ ai_gen_id }} state-question"
        data-show-for="STREAMLINE"
        style="display: none;"
      >
        <label for="Type-{{ ai_gen_id }}" class="ai-business-form__label-{{ ai_gen_id }}">
          {{ section.settings.type_label }}
          <span aria-hidden="true">*</span>
        </label>
        <select
          id="Type-{{ ai_gen_id }}"
          name="contact[type]"
          class="ai-business-form__select-{{ ai_gen_id }}"
          required
          aria-required="true"
        >
          <option value="">{{ section.settings.type_placeholder }}</option>
          <option value="01">Accommodation and food services</option>
          <option value="02">Agriculture, forestry, fishing, hunting</option>
          <option value="03">Construction</option>
          <option value="04">Finance and insurance</option>
          <option value="05">Information, publishing and communications</option>
          <option value="06">Manufacturing</option>
          <option value="07">Mining</option>
          <option value="08">Real estate</option>
          <option value="09">Rental and leasing</option>
          <option value="10">Retail trade</option>
          <option value="11">Transportation and warehousing</option>
          <option value="12">Utilities</option>
          <option value="13">Wholesale trade</option>
          <option value="14">Business services</option>
          <option value="15">Professional services</option>
          <option value="16">Education and health-care services</option>
          <option value="17">Nonprofit organization</option>
          <option value="18">Government</option>
          <option value="19">Not a business</option>
          <option value="20">Other</option>
        </select>
        <span class="ai-business-form__field-error-{{ ai_gen_id }}" data-field-error="type">
          Please select a type
        </span>
      </div>

      <div
        class="ai-business-form__field-{{ ai_gen_id }} state-question"
        data-show-for="STREAMLINE"
        style="display: none;"
      >
        <label for="Reason-{{ ai_gen_id }}" class="ai-business-form__label-{{ ai_gen_id }}">
          {{ section.settings.reason_label }}
          <span aria-hidden="true">*</span>
        </label>
        <select
          id="Reason-{{ ai_gen_id }}"
          name="contact[reason]"
          class="ai-business-form__select-{{ ai_gen_id }}"
          required
          aria-required="true"
        >
          <option value="">{{ section.settings.reason_placeholder }}</option>
          <option value="A">Federal government</option>
          <option value="B">State or local government</option>
          <option value="C">Tribal government</option>
          <option value="D">Foreign diplomat</option>
          <option value="E">Charitable organization</option>
          <option value="F">Religious organization</option>
          <option value="G">Resale</option>
          <option value="H">Agriculture Production</option>
          <option value="I">Industrial production/manufacturing</option>
          <option value="J">Direct pay permit</option>
          <option value="K">Direct Mail</option>
          <option value="L">Other</option>
          <option value="M">Educational Organization</option>
        </select>
        <span class="ai-business-form__field-error-{{ ai_gen_id }}" data-field-error="reason">
          Reason for exemption
        </span>
      </div>

      <div
        class="ai-business-form__field-{{ ai_gen_id }} state-question"
        data-show-for="STREAMLINE"
        style="display: none;"
      >
        <label for="ID-{{ ai_gen_id }}" class="ai-business-form__label-{{ ai_gen_id }}">
          {{ section.settings.id_label }}
          <span aria-hidden="true">*</span>
        </label>
        <input
          type="text"
          id="ID-{{ ai_gen_id }}"
          name="contact[id]"
          class="ai-business-form__input-{{ ai_gen_id }}"
          required
          aria-required="true"
          autocorrect="off"
          autocapitalize="off"
          autocomplete="id"
        >
        <span class="ai-business-form__field-error-{{ ai_gen_id }}" data-field-error="id">
          Please enter a valid identification number
        </span>
      </div>

      <button type="submit" class="ai-business-form__button-{{ ai_gen_id }}">
        {{ section.settings.button_text }}
      </button>
    </div>

    {%- if form.posted_successfully? -%}
      <div class="ai-business-form__success-{{ ai_gen_id }}" style="display: section;">
        {{ section.settings.success_message }}
      </div>
    {%- endif -%}

    {%- if form.errors -%}
      <div class="ai-business-form__error-{{ ai_gen_id }}" style="display: section;">
        {{ section.settings.error_message }}
      </div>
    {%- endif -%}
  {%- endform -%}
</div>

<script>
  (function () {
    const form = document.querySelector('.ai-business-form-{{ ai_gen_id }} form');

    function getStateFromURL() {
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.has('state')) {
        return urlParams.get('state').toUpperCase();
      } else {
        return 'STREAMLINE'; // default fallback
      }
    }

    function updateFieldVisibilityBasedOnState(stateCode) {
      const allStateQuestions = document.querySelectorAll('.state-question');

      allStateQuestions.forEach((field) => {
        const showFor = field.getAttribute('data-show-for');
        const acceptedStates = showFor ? showFor.split(',').map((s) => s.trim().toUpperCase()) : [];
        console.log('wool acceptedStates: ', acceptedStates);

        if (acceptedStates.includes(stateCode)) {
          field.style.display = 'flex'; // or block, depending on your layout
          const requiredInput = field.querySelector('[required]');
          if (requiredInput) requiredInput.setAttribute('aria-required', 'true');
        } else {
          field.style.display = 'none';
          const input = field.querySelector('input, select, textarea');
          if (input) {
            input.removeAttribute('required');
            input.removeAttribute('aria-required');
            input.removeAttribute('aria-invalid');
            // Also hide any visible error
            const errorEl = field.querySelector('[data-field-error]');
            if (errorEl) errorEl.style.display = 'none';
          }
        }
      });
    }

    function validateEmail(email) {
      const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      return re.test(email);
    }

    if (form) {
      const stateCode = getStateFromURL();
      console.log('state code: ', stateCode);
      updateFieldVisibilityBasedOnState(stateCode);

      form.addEventListener('submit', async function (event) {
        let isValid = true;
        const visibleInputs = form.querySelectorAll(
          '.state-question:not([style*="display: none"]) input[required], .state-question:not([style*="display: none"]) select[required]'
        );

        visibleInputs.forEach((input) => {
          const errorElement = form.querySelector(
            `[data-field-error="${input.name.replace('contact[', '').replace(']', '')}"]`
          );

          if (!input.value.trim()) {
            isValid = false;
            input.setAttribute('aria-invalid', 'true');
            if (errorElement) errorElement.style.display = 'block';
          } else {
            input.removeAttribute('aria-invalid');
            if (errorElement) errorElement.style.display = 'none';
          }

          if (input.type === 'email' && input.value.trim() && !validateEmail(input.value)) {
            isValid = false;
            input.setAttribute('aria-invalid', 'true');
            if (errorElement) errorElement.style.display = 'block';
          }
        });

        if (!isValid) {
          return;
        }

        // ✨ Begin PDF logic after validation
        const formData = new FormData(form);
        const businessName = formData.get('contact[business_name]');
        const contactName = formData.get('contact[name]');
        const email = formData.get('contact[email]');
        const type = formData.get('contact[type]');
        const reason = formData.get('contact[reason]');
        const id = formData.get('contact[id]');

        console.log('type: ', type);
        console.log('reason: ', reason);

        try {
          const pdfUrl =
            'https://cdn.shopify.com/s/files/1/0248/6291/6693/files/streamline-tax-exemption.pdf?v=1731952965';
          const pdfBytes = await fetch(pdfUrl).then((res) => res.arrayBuffer());

          const { PDFDocument } = window.PDFLib;
          const pdfDoc = await PDFDocument.load(pdfBytes);
          const pdfForm = pdfDoc.getForm();
          const fields = pdfForm.getFields();

          fields.forEach((field) => {
            const name = field.getName();
            const type = field.constructor.name;
            console.log('Field type: ', type);

            if (type === 'e') {
              console.log(`--- Checkbox Group: ${name} ---`);

              // pdf-lib doesn't expose widget-level info directly,
              // but we can peek into the internal structure.
              const widgets = field.acroField.getWidgets();

              widgets.forEach((widget, index) => {
                const dict = widget.dict;
                const ap = dict.lookup(PDFLib.PDFName.of("AP")); // Appearance dictionary
                const n = ap?.lookup(PDFLib.PDFName.of("N"));     // Normal appearance

                if (n) {
                  const appearanceKeys = n.keys(); // all the possible ON values (like 'LLC', 'Corp')
                  for (const key of appearanceKeys) {
                    if (key !== PDFLib.PDFName.of("Off")) {
                      console.log(`  ➤ Widget [${index}] option: ${key.decodeText ? key.decodeText() : key}`);
                    }
                  }
                }

                // Is it currently checked?
                const currentValue = dict.get(PDFLib.PDFName.of('AS'));
                console.log(`  ↳ Widget [${index}] current value: ${currentValue?.decodeText?.() || currentValue?.name}`);
              });
            }
          });

          pdfForm.getTextField('Item.Your.Name').setText(contactName);
          pdfForm.getTextField('Item.BusinessAddress').setText(businessName);

          const typeField = pdfForm.getCheckBox('Item.Checkbox');
          console.log('typeField: ', typeField);

          const reasonField = pdfForm.getCheckBox('Item.Checkbox2');
          {% comment %} const reasonAppearances = reasonField.acroField.getOnValues(); {% endcomment %}
          {% comment %} console.log('reasonAppearances: ', reasonAppearances); {% endcomment %}

          // Optional: Set dropdowns if the PDF has them
          try {
            console.log('typeField: ', typeField);
            console.log('reasonField: ', reasonField);
            if (typeAppearances.includes(type)) {
              typeField.check(type);
            } else {
              typeField.uncheckAll();
            }
            if (reasonAppearances.includes(reason)) {
              reasonField.check(reason);
            } else {
              reasonField.uncheckAll();
            }
          } catch (err) {
            console.warn('Dropdown fields may not exist in the PDF');
          }

          pdfForm.flatten(); // prevent further editing

          const pdfBytesModified = await pdfDoc.save();

          // Download the filled PDF
          const blob = new Blob([pdfBytesModified], { type: 'application/pdf' });
          const link = document.createElement('a');
          link.href = URL.createObjectURL(blob);
          link.download = 'streamlined-exemption.pdf';
          document.body.appendChild(link);
          link.click();
          link.remove();
        } catch (err) {
          console.error('PDF generation/upload failed:', err);
        }
      });
    }
  })();
</script>

