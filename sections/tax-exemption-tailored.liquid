{% assign ai_gen_id = section.id | replace: '_', '' | downcase %}

{% style %}
    .ai-business-form-{{ ai_gen_id }} {
      max-width: 500px;
      margin: 30px auto 0 auto;
      padding: 30px;
      background-color: {{ section.settings.background_color }};
      border-radius: {{ section.settings.border_radius }}px;
    }

    .ai-business-form__heading-{{ ai_gen_id }} {
      margin-top: 0;
      margin-bottom: 20px;
      color: {{ section.settings.text_color }};
      font-size: {{ section.settings.heading_size }}px;
      text-align: {{ section.settings.text_alignment }};
    }

    .ai-business-form__description-{{ ai_gen_id }} {
      margin-bottom: 25px;
      color: {{ section.settings.text_color }};
      text-align: {{ section.settings.text_alignment }};
    }

    .basic-business-form,
    .ai-business-form__fields-{{ ai_gen_id }} {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .ai-business-form__field-{{ ai_gen_id }} {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-top: 10px;
    }

    .ai-business-form__label-{{ ai_gen_id }} {
      font-weight: 500;
      color: {{ section.settings.text_color }};
    }

    .ai-business-form__input-{{ ai_gen_id }},
    .ai-business-form__select-{{ ai_gen_id }} {
      padding: 12px 16px;
      border: 1px solid {{ section.settings.input_border_color }};
      border-radius: {{ section.settings.input_border_radius }}px;
      background-color: {{ section.settings.input_background_color }};
      color: {{ section.settings.text_color }};
    }

    .ai-business-form__continue-button,
    .ai-business-form__previous-button-{{ ai_gen_id }},
    .ai-business-form__button-{{ ai_gen_id }} {
      position: relative;
      margin-top: 20px;
      padding: 14px 28px;
      background-color: {{ section.settings.button_color }};
      color: {{ section.settings.button_text_color}};
      border: none;
      border-radius: {{ section.settings.button_border_radius }}px;
      font-weight: 500;
      cursor: pointer;
      transition: background-color 0.3s;
      width: 120px;
      display: flex;
      align-items: center;
      text-align: center;
      justify-content: center;
    }

    .ai-business-form__continue-button,
    .ai-business-form__previous-button-{{ ai_gen_id }},
    .ai-business-form__button-{{ ai_gen_id }}:hover {
      background-color: {{ section.settings.button_hover_color }};
    }

    .ai-business-form__checkout-button-{{ ai_gen_id }} {
      position: relative;
      margin-top: 20px;
      padding: 14px 28px;
      background-color: {{ section.settings.button_color }};
      color: {{ section.settings.button_text_color}};
      border: none;
      border-radius: {{ section.settings.button_border_radius }}px;
      font-weight: 500;
      cursor: pointer;
      transition: background-color 0.3s;
      display: flex;
      align-items: center;
      text-align: center;
      justify-content: center;
    }

    .ai-business-form__continue-button:disabled {
      background-color: #ccc;
      cursor: not-allowed;
      opacity: 0.6;
    }

    .ai-business-form__button--loading::after {
      content: "";
      position: absolute;
      width: 16px;
      height: 16px;
      border: 4px solid transparent;
      border-top-color: #ffffff;
      border-radius: 50%;
      animation: button-loading-spinner 1s ease infinite;
    }

    @keyframes button-loading-spinner {
      from {
        transform: rotate(0turn);
      }
      to {
        transform: rotate(1turn);
      }
    }



    .ai-business-form__success-{{ ai_gen_id }} {
      margin-top: 20px;
      padding: 15px;
      background-color: {{ section.settings.success_color }};
      color: #ffffff;
      border-radius: 4px;
      display: none;
    }

    .ai-business-form__error-{{ ai_gen_id }} {
      margin-top: 20px;
      padding: 15px;
      background-color: {{ section.settings.error_color }};
      color: #ffffff;
      border-radius: 4px;
      display: none;
    }

    .ai-business-form__field-error-{{ ai_gen_id }} {
      color: {{ section.settings.text_color }};
      font-size: 14px;
      display: none;
    }

    #optional-italicize {
      font-style: italic;
      font-size: 14px;
      color: {{ section.settings.text_color }};
    }

    @media screen and (max-width: 749px) {
      .ai-business-form-{{ ai_gen_id }} {
        padding: 20px;
      }

      .ai-business-form__continue-button {
        width: 100%;
        align-self: stretch;
      }

      .ai-business-form-{{ ai_gen_id }} {
        background-color: #ffffff;
      }
    }
  .city-state-zipcode-container {
    display: flex;
    flex-direction: row;
    gap: 5px;
    width: 100%; /* Prevents overflow */
    flex-wrap: wrap; /* Allows wrapping on smaller screens */
    box-sizing: border-box;
  }

  .city-state-zipcode-container > .ai-business-form__field-{{ ai_gen_id }} {
    flex: 1 1 0; /* Let each child shrink or grow equally */
    min-width: 0; /* Prevents children from overflowing */
    box-sizing: border-box;
  }

  .previous-submit-button-wrapper {
    display: flex;
    justify-content: space-between;
  }

  .business-form-submission-message {
    justify-content: center;
    align-items: center;
    flex-direction: column;
  }
{% endstyle %}

<div class="ai-business-form-{{ ai_gen_id }}" {{ section.shopify_attributes }}>
  <div class="business-form-wrapper">
    {% if section.settings.heading != blank %}
      <h2 class="ai-business-form__heading-{{ ai_gen_id }}">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.description != blank %}
      <div class="ai-business-form__description-{{ ai_gen_id }}">{{ section.settings.description }}</div>
    {% endif %}

    <form id="streamlineForm" method="POST" action="#">
      <div class="ai-business-form__fields-{{ ai_gen_id }}">
        <div class="basic-business-form">
          <div
            class="ai-business-form__field-{{ ai_gen_id }}"
            data-show-for="STREAMLINE"
