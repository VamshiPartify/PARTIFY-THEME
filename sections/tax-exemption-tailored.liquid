                <span aria-hidden="true">*</span>
              </label>
            {% endcomment %}
            <input
              type="text"
              id="LastName-{{ ai_gen_id }}"
              name="contact[lastName]"
              class="ai-business-form__input-{{ ai_gen_id }}"
              placeholder="Last Name"
              required
              aria-required="true"
