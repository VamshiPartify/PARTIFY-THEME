            {% endcomment %}
            <input
              type="text"
              id="BusinessName-{{ ai_gen_id }}"
              name="contact[business_name]"
              class="ai-business-form__input-{{ ai_gen_id }}"
              placeholder="Company Name"
              required
              aria-required="true"
            >
            <span class="ai-business-form__field-error-{{ ai_gen_id }}" data-field-error="business_name">
              Please enter your business name
            </span>
          </div>

          <div
            class="ai-business-form__field-{{ ai_gen_id }}"
            data-show-for="STREAMLINE"
          >
            {% comment %}
              <label for="FirstName-{{ ai_gen_id }}" class="ai-business-form__label-{{ ai_gen_id }}">
                {{ section.settings.first_name_label }}
                <span aria-hidden="true">*</span>
              </label>
            {% endcomment %}
            <input
              type="text"
              id="FirstName-{{ ai_gen_id }}"
              name="contact[firstName]"
              class="ai-business-form__input-{{ ai_gen_id }}"
              placeholder="First Name"
