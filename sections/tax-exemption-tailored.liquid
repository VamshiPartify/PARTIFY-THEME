{% for block in section.blocks %}
  {% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-business-form-{{ ai_gen_id }} {
    max-width: 100%;
    margin: 0 auto;
    padding: 30px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-business-form__heading-{{ ai_gen_id }} {
    margin-top: 0;
    margin-bottom: 20px;
    color: #000;
    font-size: {{ block.settings.heading_size }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-business-form__description-{{ ai_gen_id }} {
    margin-bottom: 25px;
    color: #000;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-business-form__fields-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-business-form__field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-business-form__label-{{ ai_gen_id }} {
    font-weight: 500;
    color: #000;
  }

  .ai-business-form__input-{{ ai_gen_id }},
  .ai-business-form__select-{{ ai_gen_id }} {
    padding: 12px 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    background-color: {{ block.settings.input_background_color }};
    color: #000;
  }

  .ai-business-form__button-{{ ai_gen_id }} {
    margin-top: 20px;
    padding: 14px 28px;
    background-color: {{ block.settings.button_color }};
    color: #000;
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.3s;
    align-self: {{ block.settings.button_alignment }};
  }

  .ai-business-form__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-business-form__success-{{ ai_gen_id }} {
    margin-top: 20px;
    padding: 15px;
    background-color: {{ block.settings.success_color }};
    color: #ffffff;
    border-radius: 4px;
    display: none;
  }

  .ai-business-form__error-{{ ai_gen_id }} {
    margin-top: 20px;
    padding: 15px;
    background-color: {{ block.settings.error_color }};
    color: #ffffff;
    border-radius: 4px;
    display: none;
  }

  .ai-business-form__field-error-{{ ai_gen_id }} {
    color: #000;
    font-size: 14px;
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-business-form-{{ ai_gen_id }} {
      padding: 20px;
    }
    
    .ai-business-form__button-{{ ai_gen_id }} {
      width: 100%;
      align-self: stretch;
    }
  }
{% endstyle %}

<div class="ai-business-form-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-business-form__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}
  
  {% if block.settings.description != blank %}
    <div class="ai-business-form__description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
  {% endif %}
  
  {%- form 'contact' -%}
    <div class="ai-business-form__fields-{{ ai_gen_id }}">
      <div class="ai-business-form__field-{{ ai_gen_id }}">
        <label for="BusinessName-{{ ai_gen_id }}" class="ai-business-form__label-{{ ai_gen_id }}">
          {{ block.settings.business_name_label }}
          <span aria-hidden="true">*</span>
        </label>
        <input 
          type="text" 
          id="BusinessName-{{ ai_gen_id }}" 
          name="contact[business_name]" 
          class="ai-business-form__input-{{ ai_gen_id }}"
          required
          aria-required="true"
        >
        <span class="ai-business-form__field-error-{{ ai_gen_id }}" data-field-error="business_name">
          Please enter your business name
        </span>
      </div>
      
      <div class="ai-business-form__field-{{ ai_gen_id }}">
        <label for="ContactName-{{ ai_gen_id }}" class="ai-business-form__label-{{ ai_gen_id }}">
          {{ block.settings.contact_name_label }}
          <span aria-hidden="true">*</span>
        </label>
        <input 
          type="text" 
          id="ContactName-{{ ai_gen_id }}" 
          name="contact[name]" 
          class="ai-business-form__input-{{ ai_gen_id }}"
          required
          aria-required="true"
        >
        <span class="ai-business-form__field-error-{{ ai_gen_id }}" data-field-error="contact_name">
          Please enter your name
        </span>
      </div>
      
      <div class="ai-business-form__field-{{ ai_gen_id }}">
        <label for="Email-{{ ai_gen_id }}" class="ai-business-form__label-{{ ai_gen_id }}">
          {{ block.settings.email_label }}
          <span aria-hidden="true">*</span>
        </label>
        <input 
          type="email" 
          id="Email-{{ ai_gen_id }}" 
          name="contact[email]" 
          class="ai-business-form__input-{{ ai_gen_id }}"
          required
          aria-required="true"
          autocorrect="off"
          autocapitalize="off"
          autocomplete="email"
        >
        <span class="ai-business-form__field-error-{{ ai_gen_id }}" data-field-error="email">
          Please enter a valid email address
        </span>
      </div>
      
      <div class="ai-business-form__field-{{ ai_gen_id }}">
        <label for="State-{{ ai_gen_id }}" class="ai-business-form__label-{{ ai_gen_id }}">
          {{ block.settings.state_label }}
          <span aria-hidden="true">*</span>
        </label>
        <select 
          id="State-{{ ai_gen_id }}" 
          name="contact[state]" 
          class="ai-business-form__select-{{ ai_gen_id }}"
          required
          aria-required="true"
        >
          <option value="">{{ block.settings.state_placeholder }}</option>
          <option value="CA">California</option>
          <option value="NY">New York</option>
          <option value="TX">Texas</option>
          <option value="FL">Florida</option>
          <option value="IL">Illinois</option>
        </select>
        <span class="ai-business-form__field-error-{{ ai_gen_id }}" data-field-error="state">
          Please select a state
        </span>
      </div>
      
      <button type="submit" class="ai-business-form__button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </button>
    </div>
    
    {%- if form.posted_successfully? -%}
      <div class="ai-business-form__success-{{ ai_gen_id }}" style="display: block;">
        {{ block.settings.success_message }}
      </div>
    {%- endif -%}
    
    {%- if form.errors -%}
      <div class="ai-business-form__error-{{ ai_gen_id }}" style="display: block;">
        {{ block.settings.error_message }}
      </div>
    {%- endif -%}
  {%- endform -%}
</div>
  {% endfor %}

<script>
  console.log('ai gen id: ', '{{ ai_gen_id }}');
  (function() {
    const form = document.querySelector('.ai-business-form-{{ ai_gen_id }} form');
    
    if (form) {
      form.addEventListener('submit', function(event) {
        let isValid = true;
        const inputs = form.querySelectorAll('input[required], select[required]');
        
        inputs.forEach(input => {
          const errorElement = form.querySelector(`[data-field-error="${input.name.replace('contact[', '').replace(']', '')}"]`);
          
          if (!input.value.trim()) {
            isValid = false;
            input.setAttribute('aria-invalid', 'true');
            if (errorElement) errorElement.style.display = 'block';
          } else {
            input.removeAttribute('aria-invalid');
            if (errorElement) errorElement.style.display = 'none';
          }
          
          if (input.type === 'email' && input.value.trim() && !validateEmail(input.value)) {
            isValid = false;
            input.setAttribute('aria-invalid', 'true');
            if (errorElement) errorElement.style.display = 'block';
          }
        });
        
        if (!isValid) {
          event.preventDefault();
        }
      });
      
      function validateEmail(email) {
        const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        return re.test(email);
      }
    }
  })();
</script>

