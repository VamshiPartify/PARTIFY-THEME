<style>
    .order-form-wrapper {
      margin: 0;
      font-family: Lato, sans-serif;
      display: flex;
      justify-content: center;
      align-items: center;
    }
  
    .order-form {
      width: 100%;
      max-width: 400px;
      padding: 2rem;
      background: white;
      border-radius: 20px;
      box-shadow: 0px 4px 20px rgba(0, 0, 0, 0.1);
      text-align: center;
    }
  
    .order-form p {
      margin-bottom: 1rem;
      font-size: 1rem;
      color: #555;
    }
  
    #order-lookup-form {
      display: flex;
      flex-direction: column;
    }
  
    #order-lookup-form input[type="text"] {
      padding: 0.75rem;
      border: 1px solid #ccc;
      border-radius: 8px;
      margin-bottom: 1rem;
      font-size: 1rem;
      width: 100%;
      transition: box-shadow 0.3s ease-in-out, border 0.3s ease-in-out;
    }
  
    #order-lookup-form input[type="text"]:focus {
      outline: none;
      border-color: #007aff;
      box-shadow: 0 0 0 1px #0073e6;
    }
  
    #order-lookup-form button[type="submit"] {
      padding: 0.75rem;
      font-size: 1rem;
      background-color: #0c1a94;
      color: white;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      transition: background-color 0.3s ease;
    }
  
    #order-lookup-form button[type="submit"]:hover {
      background-color:rgb(61, 73, 177);
    }
  
    #order-details {
      margin-top: 2rem;
      padding: 2rem;
      background: #f9f9f9;
      border-radius: 12px;
      box-shadow: 0px 4px 20px rgba(0, 0, 0, 0.1);
      text-align: left;
      display: flex;
      justify-content: center;
      align-items: center;
      flex-direction: column;
    }
  
    #order-details h2 {
      margin-bottom: 1rem;
      font-size: 1.25rem;
      color: #333;
    }
  
    .metafield {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
      grid-template-rows: repeat(6, auto);
      gap: 16px;
      padding: 1rem;
      width: fit-content;
      text-align: end;
    }

    .metafield-grid .placeholder {
      background-color: #f0f0f0; /* Light grey background */
      border: 1px dashed #ccc; /* Dashed border */
      height: 40px; /* Fixed height for empty placeholders */
    }
  
    .metafield h3 {
      margin-bottom: 0.5rem;
      font-size: 1rem;
      color: #333;
    }
  
    .metafield p {
      margin: 0.25rem 0;
      font-size: 14px;
      color: #555;
    }

    .metafield span {
      font-weight: 900;
      font-size: 16px;
    }
  
    .hidden {
      display: none;
    }
    
    .order-container {
      display: flex;
      flex-direction: column;
      margin-bottom: 20px;
      border: 1px solid #777777;
      border-radius: 20px;
      width: fit-content;
      max-width: 375px;
    }

    .order-header {
      padding: 10px 16px;
      border-bottom: 1px solid #777777;
    }

    #order-status-tracker {
      display: flex;
      flex-direction: row;
      text-align: center;
      margin: 20px 10px; /* Center the entire tracker */
      max-width: 350px; /* Set max-width */
      min-height: 200px;
    }
    
    .status-line {
      display: flex;
      flex-direction: column; /* Stack dots vertically */
      justify-content: space-between;
      position: relative;
      margin-bottom: 10px;
      max-width: 350px; /* Ensure the line does not exceed the max-width */
      margin: 0; /* Center the status line */
    }
    
    .dot {
      width: 14px;
      height: 14px;
      border-radius: 50%;
      border: 3px solid #0c1a94;
      background-color: #f9f9f9;
      transition: background-color 0.3s;
      z-index: 2;
      margin: 0;
    }
    
    .dot.filled {
      background-color: #0c1a94; /* Green color for filled dots */
      border-color: #0c1a94;
      height: 14px;
      width: 14px;
      margin: 0;
    }
    
    .status-line::before {
      content: '';
      position: absolute;
      left: 50%; /* Center the line horizontally */
      top: 0;
      bottom: 0;
      width: 2px; /* Line thickness */
      background-color: #ccc; /* Line color */
      z-index: 1;
      transform: translateX(-50%); /* Center the line */
    }
    
    .status-line .dot.filled + .dot {
      background-color: #0c1a94; /* Fill the next dot */
      border-color: #0c1a94;
    }
    
    .status-labels {
      display: flex;
      flex-direction: column; /* Stack labels vertically */
      justify-content: space-between;
      text-align: start;
      margin-top: 10px;
      max-width: 350px; /* Ensure labels are centered within the max-width */
      margin: 0 0 0 10px; /* Center the labels */
    }
    
    .status-label {
      font-size: 14px;
      color: #555;
      margin-bottom: 0; /* Space between labels */
    }

    .status-label p {
      font-weight: 800;
      margin: 0;
    }

    .status-label h5 {
      color: 777777;
      font-size: 14px;
      font-weight: 500;
      margin: 0;
    }

    .status-tracker-metafield-wrapper {
      display: flex;
      flex-direction: row;
      margin-bottom: 20px;
      {% comment %} border: 1px solid #777777; {% endcomment %}
      {% comment %} border-radius: 20px; {% endcomment %}
      width: fit-content;
    }
    
  </style>
  
  <article class="order-lookup">
    <header class="page-masthead">
      <h1 class="page-title">Track My Order</h1>
    </header>
  
    <div class="order-form-wrapper">
      <div class="order-form">
        {% comment %} <p>Enter your order number to view additional details:</p> {% endcomment %}
        <form id="order-lookup-form">
          <input type="text" id="order-number" placeholder="U97485" required />
          <button type="submit">Track My Order</button>
        </form>
      </div>
    </div>

    {% comment %} <div id="as-root"></div><script>(function(e,t,n){var r,i=e.getElementsByTagName(t)[0];if(e.getElementById(n))return;r=e.createElement(t);r.id=n;r.src="https://button.aftership.com/all.js?username=partifyusa123";i.parentNode.insertBefore(r,i)})(document,"script","aftership-jssdk")</script>

    <div class="as-track-button" data-size="medium" data-domain="track.partify.store/" data-btn-label="Track" data-tracking-number="642145502"></div>
  
    <iframe
      style="width: 100%;"
      id="as-tracking-page"
      src="https://username.aftership.com?username=partifyusa123&iframe=1"
      scrolling="no"
      frameborder="0"
      >
      </iframe> {% endcomment %}


    <div id="order-details" style="display: none;">
      <h2>Order Details</h2>
      <div id="order-metadata"></div>
    </div>
  </article>
  
  <script>

    {% comment %} const iframe = document.querySelector("#as-tracking-page");
    window.addEventListener("message", (event) => {
      if (
        event.data &&
        event.data.type === "resize" &&
        typeof event.data.scrollHeight === "number" &&
        iframe
      ) {
        iframe.style.height = event.data.scrollHeight + "px";
      }
    });
  
    // support widget float
    window.addEventListener("message", (event) => {
    if (
      event.data &&
      event.data.type === "widgetScriptLoad" &&
      typeof event.data.scripts === "object"
    ) {
      event.data.scripts.forEach((script) => {
        const scriptDom = document.createElement("script");
        scriptDom.innerHTML = script;
        document.body.appendChild(scriptDom);
        window.postMessage({ type: "hideAllWidget" }, "*");
      });
    }
    }); {% endcomment %}
    function formatDateToLocalTime(isoString) {
      const date = new Date(isoString);
    
      date.setHours(date.getHours());
    
      const hours = date.getHours();
      const minutes = date.getMinutes();
      const isPM = hours >= 12;
    
      const formattedHours = ((hours + 11) % 12) + 1;
      const formattedMinutes = minutes.toString().padStart(2, '0');
      const period = isPM ? 'PM' : 'AM';
    
      const day = date.getDate().toString().padStart(2, '0');
      const month = (date.getMonth() + 1).toString().padStart(2, '0'); // Months are 0-indexed
      const year = date.getFullYear();
    
      return `${formattedHours}:${formattedMinutes} ${period} ${month}-${day}-${year}`;
    }
    


    document.getElementById('order-lookup-form').addEventListener('submit', async function (e) {
      e.preventDefault();
  
      const orderNumber = document.getElementById('order-number').value.toString();
      const metadataDisplay = document.getElementById('order-metadata');
      const orderDetails = document.getElementById('order-details');
  
      // Clear previous order details before adding new ones
      if(metadataDisplay) {
        metadataDisplay.innerHTML = '';
      }
  
      if (!orderNumber) {
        alert('Please enter a valid order number.');
        return;
      }
  
      try {
        // Replace with your actual Shopify API call logic
        const response = await fetch('https://us-east5-order-status-tracking-447120.cloudfunctions.net/order-status-fetcher', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ orderId: "name:" + orderNumber }),
        });
  
        if (!response.ok) {
          throw new Error(`Error fetching order details. Status: ${response.status}`);
        }
  
        const data = await response.json();
        console.log('Order Metafields:', data);
  
        if (data && data.data && data.data.orders && data.data.orders.edges[0] && data.data.orders.edges[0].node.metafields.nodes.length > 0) {
          document.getElementById('order-details').style.display = 'flex';
          
          const metafields = data.data.orders.edges[0].node.metafields.nodes;
          const lineItems = data.data.orders.edges[0].node.lineItems.edges;
  
          // Group metafields by rawKey
          const metafieldGroups = {};
          const skuGroups = {};
  
          metafields.forEach((edge) => {
            const rawValue = edge.value;
            const rawKey = edge.key;
  
            try {
              if (rawKey !== "production_status") {
                const parsedArray = JSON.parse(rawValue);
                if (Array.isArray(parsedArray)) {
                  parsedArray.forEach((metafieldValue) => {
                    const [code, timestamp] = metafieldValue.split('_');
  
                    // Group by rawKey
                    if (!metafieldGroups[rawKey]) {
                      metafieldGroups[rawKey] = [];
                    }
                    metafieldGroups[rawKey].push({ code, timestamp });
                    if(!skuGroups[code]) {
                      skuGroups[code] = [];
                    }
                    skuGroups[code].push({ rawKey, timestamp });
                  });
                } else {
                  console.log('Unexpected metafield format:', rawValue);
                }
              }
            } catch (error) {
              console.error('Error parsing metafield value:', rawValue, error);
            }
          });
  
          // Clear previous content in orderDetails before appending new data
          if(orderDetails) {
            orderDetails.innerHTML = '<h2>Order Details</h2>';
          }
  
          
          // Create metafield sections dynamically for each individual product in the order
          Object.keys(skuGroups).forEach((key) => {
            const group = skuGroups[key];
            group.push({ rawKey: 'status_ordered', timestamp: formatDateToLocalTime(data.data.orders.edges[0].node.createdAt) });
  
            // Create section for each rawKey
            const metafieldSection = document.createElement('div');
            metafieldSection.classList.add('metafield');
            const header = document.createElement('div');
            header.classList.add('order-header');
            header.textContent = lineItems.find((item) => item.node.variant.sku.split('.')[0] === key).node.title;

            const totalRows = 6;

            const statusRowMap = {
              "status_ordered": 5,
              "status_prepared": 4,
              "status_mixed": 3,
              "status_painted": 2,
              "status_packaged": 1,
              "status_shipped": 0,
            };
  
            const rows = Array(Object.keys(statusRowMap).length).fill(null);

            // Iterate through the group and populate the rows array
            group.forEach((item) => {
              const index = statusRowMap[item.rawKey];
              const codeP = document.createElement('p');
              let date = item.timestamp.split(' ')[2];
              let time = item.timestamp.split(' ')[0] + ' ' + item.timestamp.split(' ')[1];
              if(time.startsWith('0')) {
                time = time.substring(1);
              }
              codeP.innerHTML = `<span>${date}</span><br>${time}`;
              
              rows[index] = codeP;
            });
            
            rows.forEach((row) => {
              const codeP = row || document.createElement('p');
              if (!row) {
                codeP.innerHTML = `Pending Completion<br>TBD`;
              }
              metafieldSection.appendChild(codeP);
            });

            const orderStatusTracker = document.createElement('div');
            orderStatusTracker.id = 'order-status-tracker';

            const statusLabels = document.createElement('div');
            statusLabels.classList.add('status-labels');

            // Create the 6 status labels
            const labels = ['Shipped', 'Packaged', 'Painted', 'Mixed', 'Prepared', 'Ordered'];
            labels.forEach((label, index) => {
              const statusLabel = document.createElement('span');
              statusLabel.classList.add('status-label');
              if(rows[index] !== null) {
                statusLabel.innerHTML = `<p>${label}</p>`;
              } else {
                statusLabel.innerHTML = `<h5>${label}</h5`;
              }
              statusLabels.appendChild(statusLabel);
            });

            const statusLine = document.createElement('div');
            statusLine.classList.add('status-line');

            for (let i = 0; i < 6; i++) {
              const dot = document.createElement('span');
              if(rows[i] !== null) {
                dot.classList.add('dot', 'filled');
              } else {
                dot.classList.add('dot');
              }
              statusLine.appendChild(dot);
            }

            orderStatusTracker.appendChild(statusLine);
            orderStatusTracker.appendChild(statusLabels);

            const orderContainer = document.createElement('div');
            orderContainer.classList.add('order-container');

            const wrapperDiv = document.createElement('div');
            wrapperDiv.classList.add('status-tracker-metafield-wrapper');

            orderContainer.appendChild(header);
            orderContainer.appendChild(wrapperDiv);

            wrapperDiv.appendChild(metafieldSection);
            wrapperDiv.appendChild(orderStatusTracker); 

            orderDetails.appendChild(orderContainer);
          });
        } else {
          document.getElementById('order-details').style.display = 'flex';
          if(orderDetails) {
            orderDetails.innerHTML = 'Order not found.';
          }
        }
      } catch (error) {
        document.getElementById('order-details').style.display = 'flex';
        console.error('Error fetching order details:', error);
        if(orderDetails) {
          orderDetails.innerHTML = 'Error fetching order details.';
        }
      }
    });
  </script>
  