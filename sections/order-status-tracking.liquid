<style>
  .order-form-wrapper {
    margin: 0;
    font-family: Lato, sans-serif;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .order-form {
    width: 100%;
    max-width: 400px;
    padding: 2rem;
    background: white;
    border-radius: 20px;
    box-shadow: 0px 4px 20px rgba(0, 0, 0, 0.1);
    text-align: center;
    margin: 0 16px;
  }

  .order-form p {
    margin-bottom: 1rem;
    font-size: 1rem;
    color: #555;
  }

  #order-lookup-form {
    display: flex;
    flex-direction: column;
  }

  #order-lookup-form input[type="text"] {
    padding: 0.75rem;
    border: 1px solid #ccc;
    border-radius: 8px;
    margin-bottom: 1rem;
    font-size: 1rem;
    width: 100%;
    transition: box-shadow 0.3s ease-in-out, border 0.3s ease-in-out;
  }

  #order-lookup-form input[type="text"]:focus {
    outline: none;
    border-color: #007aff;
    box-shadow: 0 0 0 1px #0073e6;
  }

  #order-details {
    margin-top: 2rem;
    padding: 1rem;
    {% comment %} background: #f9f9f9;
    border-radius: 12px;
    box-shadow: 0px 4px 20px rgba(0, 0, 0, 0.1); {% endcomment %}
    text-align: left;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
  }

  #order-details h2 {
    margin-bottom: 1rem;
    font-size: 1.25rem;
    color: #333;
  }

  .metafield {
    display: grid;
    justify-content: space-between;
    {% comment %} grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); {% endcomment %}
    grid-template-rows: repeat(var(--dot-count, 5), auto);
    gap: 16px;
    padding: 1rem 0 1rem 1rem;
    width: 47%;
    text-align: end;
    align-items: center;
  }

  .metafield-grid .placeholder {
    background-color: #f0f0f0; /* Light grey background */
    border: 1px dashed #ccc; /* Dashed border */
    height: 40px; /* Fixed height for empty placeholders */
  }

  .metafield h3 {
    margin-bottom: 0.5rem;
    font-size: 1rem;
    color: #333;
  }

  .metafield p {
    margin: 0.25rem 0;
    font-size: 14px;
    color: #555;
    width: fit-content;
  }

  .metafield span {
    font-weight: 900;
    font-size: 16px;
  }

  .hidden {
    display: none;
  }

  @media screen and (max-width: 400px) {
    .order-container {
      display: flex;
      flex-direction: column;
      margin-bottom: 20px;
      border: 1px solid #777777;
      border-radius: 20px;
      max-width: 100%;
      min-width: 80%;
      overflow: hidden;
    }
  }
  
  @media screen and (min-width: 401px) {
    .order-container {
      display: flex;
      flex-direction: column;
      margin-bottom: 20px;
      border: 1px solid #777777;
      border-radius: 20px;
      max-width: 375px;
      min-width: 375px;
      overflow: hidden;
    }
  }


  .order-header-container{
    padding: 10px 16px;
    border-bottom: 1px solid #777777;
    display: flex;
    flex-direction: row;
    align-items: center;
    background: #fff;
  }

  .product-image img {
    width: 50px;
    height: 50px;
    object-fit: contain;
    margin-right: 10px
}

  .order-header {
    text-align: left;
    font-weight: 700;
  }

  #order-status-tracker {
    align-items: center;
    justify-content: center;
    gap: 20px;
    position: relative;
    min-height: 200px;
    padding: 10px 0;
  }

  .code-container {
    display: grid;
    grid-template-rows: repeat(auto-fit, minmax(40px, auto));
    gap: 20px;
    justify-items: end;
}

  .code-p {
    text-align: end;
  }

  .code-p span {
    font-weight: 900;
    font-size: 16px;
    color: #555;
    width: fit-content;
  }

  .code-p p {
    margin: 0;
    font-size: 1rem;
    color: #333;
  }

  @media screen and (max-width: 369px) {
    .code-container {
        display: grid;
        justify-items: end;
        width: 85%;
    }
  }

  @media screen and (min-width: 370px) {
    .code-container {
        display: grid;
        justify-items: end;
        width: 90%;
    }
  }

  @media screen and (min-width: 385px) {
    .code-container {
        display: grid;
        justify-items: end;
        width: 95%;
    }
  }

  @media screen and (min-width: 400px) {
    .code-container {
        display: grid;
        justify-items: end;
        width: 100%;
    }
  }
  
  .status-line {
    position: absolute;
    left: 50%;
    top: 20px;
    width: 2px;
    height: calc(100% - 110px);
    {% comment %} background-color: lightgray; {% endcomment %}
    transform: translateX(-50%);
    z-index: 1;
}

  .dot-container {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%; /* Ensure it takes up the full middle column */
    height: 100%; /* Ensure it takes up the full row height */
  }
  
  .dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 3px solid #0c1a94;
    background-color: #f9f9f9;
    transition: background-color 0.3s;
    z-index: 2;
    margin: 0;
  }
  
  .dot.filled {
    background-color: #0c1a94; /* Green color for filled dots */
    border-color: #0c1a94;
    height: 14px;
    width: 14px;
    margin: 0;
  }
  
  .status-line::before {
    content: '';
    position: absolute;
    left: 50%; /* Center the line horizontally */
    top: 35px;
    bottom: 0;
    width: 2px; /* Line thickness */
    background-color: #0c1a94; /* Line color */
    z-index: 1;
    transform: translateX(-50%); /* Center the line */
    height: 100%;
  }

  .status-line::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 30px;
    width: 2px;
    height: var(--filled-height, 0%);
    background-color: #ccc; /* Filled line color */
    z-index: 1;
    transform: translateX(-50%);
    transition: height 0.3s ease-in-out;
    height: 100%;
  }
  
  .status-line .dot.filled + .dot {
    background-color: #0c1a94; /* Fill the next dot */
    border-color: #0c1a94;
  }
  
  .status-labels {
    display: grid;
    {% comment %} grid-template-rows: repeat(auto-fit, minmax(40px, auto)); {% endcomment %}
    grid-template-rows: repeat(var(--dot-count, 5), auto);
    gap: 20px;
    text-align: start;
    margin-left: 10px; /* Ensure labels are positioned correctly */
    height: 90%;
    margin-top: 10px;
  }
  
  .status-label {
    font-size: 14px;
    color: #555;
    margin-bottom: 0;
    padding-right: 15px;
  }

  .status-label span {
    font-size: 16px;
    font-weight: 800;
    margin: 0;
  }

  .status-label p {
    color: #777777;
    font-size: 14px;
    font-weight: 500;
    margin: 0;
  }


  .status-tracker-metafield-wrapper {
    background-color: #f9f9f9;
    box-shadow: inset 0px 0px 6px rgba(0, 0, 0, 0.1);
  }

  .expand-for-details-container {
    background-color: #0c1a94;
    color: white;
    cursor: pointer;
    display: flex;
    justify-content: center;
  }

  .expand-for-details-container p {
    margin: 10px;
  }

  .button {
    padding: 0.75rem;
    font-size: 1rem;
    background-color: #0c1a94;
    color: white;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: background-color 0.3s ease;
    min-height: 43px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .button:active {
    background:rgb(39, 56, 211)
  }

  .button:hover {
    background-color:rgb(61, 73, 177);
  }

  .button:disabled {
    background-color: #ccc;
    cursor: no-drop;
  }

  .button__text {
    transition: all 0.2s;
  }

  .button--loading::after {
    content: "";
    position: absolute;
    width: 16px;
    height: 16px;
    margin: auto;
    border: 4px solid transparent;
    border-top-color: #ffffff;
    border-radius: 50%;
    animation: button-loading-spinner 1s ease infinite;
  }
  
  @keyframes button-loading-spinner {
    from {
        transform: rotate(0turn);
    }

    to {
        transform: rotate(1turn);
    }
  }

  @keyframes pulseHeight {
    0% { height: var(--filled-height-start, 0%); }
    80% { height: var(--filled-height-end, 80%); }
    100% { height: var(--filled-height-end, 100%); }
  }
  
  .status-line.pending::after {
    animation: pulseHeight 1.2s ease-in infinite;
  }

  {% comment %} .order-tracking-warning {
    background-color: #ffefc1;
    color: #7a4f01;
    border: 1px solid #e0a800;
    padding: 12px 16px;
    margin-bottom: 20px;
    border-radius: 6px;
    font-size: 16px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  
  .order-tracking-warning p {
    margin: 0;
  }
  
  .order-tracking-warning::before {
    content: "⚠️";
    font-size: 20px;
  } {% endcomment %}
  
</style>

<article class="order-lookup">
      <!-- Order Tracking Warning -->
      {% comment %} <div class="order-tracking-warning">
        <p>
          ⚠️ <strong>Notice:</strong> Our order tracking system is currently experiencing issues. 
          The results may not be accurate at this time. We appreciate your patience.
        </p>
      </div> {% endcomment %}

  <header class="page-masthead">
    <h1 class="page-title">Track Your Order</h1>
  </header>

  <div class="order-form-wrapper">
    <div class="order-form">
      {% comment %} <p>Enter your order number to view additional details:</p> {% endcomment %}
      <form id="order-lookup-form">
        <input type="text" id="order-number" placeholder="U12345" required />
        <input 
          type="text" 
          id="email-input" 
          placeholder="Email" 
          required 
        />
        <button type="submit" class="button" id="track-order-btn" disabled>
          <span class="button__text">Track Order</span>
        </button>
      </form>
    </div>
  </div>


  <div id="order-details" style="display: none;">
    <h2>Order Details</h2>
    <div id="order-metadata"></div>
  </div>
</article>

<script>
  function formatDateToLocalTime(isoString) {
    const date = new Date(isoString);
  
    date.setHours(date.getHours());
  
    const hours = date.getHours();
    const minutes = date.getMinutes();
    const isPM = hours >= 12;
  
    const formattedHours = ((hours + 11) % 12) + 1;
    const formattedMinutes = minutes.toString().padStart(2, '0');
    const period = isPM ? 'PM' : 'AM';
  
    const day = date.getDate().toString().padStart(2, '0');
    const month = (date.getMonth() + 1).toString().padStart(2, '0'); // Months are 0-indexed
    const year = date.getFullYear();
  
    return `${formattedHours}:${formattedMinutes} ${period} ${month}-${day}-${year}`;
  }

  function formatDateTimeFromMS(ms) {
    const date = new Date(ms);
    
    // Extract date components
    let month = date.getMonth() + 1; // Months are zero-based
    let day = date.getDate();
    let year = date.getFullYear();
    
    // Extract time components
    let hours = date.getHours();
    let minutes = date.getMinutes();
    let ampm = hours >= 12 ? 'PM' : 'AM';
    
    // Convert hours to 12-hour format
    hours = hours % 12;
    hours = hours ? hours : 12; // Convert 0 to 12
    
    // Format components to ensure two-digit representation where needed
    month = month.toString().padStart(2, '0');
    day = day.toString().padStart(2, '0');
    minutes = minutes.toString().padStart(2, '0');
    
    return `${month}-${day}-${year} ${hours}:${minutes} ${ampm}`;
}  

const getIpAddress = async () => {
  try {
    const response = await fetch('https://api.ipify.org?format=json');
    const data = await response.json();
    return data.ip; // Returns the client's public IP
  } catch (error) {
    console.error("Error fetching IP address:", error);
    return null;
  }
};
  




  document.addEventListener("DOMContentLoaded", function () {
    const form = document.getElementById("order-lookup-form");
    const button = form.querySelector(".button");
    const buttonText = form.querySelector(".button__text");
    const email = document.getElementById('email-input');
    const trackOrderBtn = document.getElementById("track-order-btn");

    function validateEmail(email) {
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      return emailRegex.test(email);
    }

    function handleEmailInput() {
      if (validateEmail(email.value)) {
        trackOrderBtn.removeAttribute("disabled"); // Enable button
      } else {
        trackOrderBtn.setAttribute("disabled", "true"); // Disable button
      }
    }
  
    email.addEventListener("input", handleEmailInput);


    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      buttonText.style.display = "none";
      button.disabled = true;
      button.classList.add("button--loading");
      
      const submittedEmail = document.getElementById('email-input').value.toString();
      const orderNumber = document.getElementById('order-number').value.toString();
      const metadataDisplay = document.getElementById('order-metadata');
      const orderDetails = document.getElementById('order-details');
  
      // Clear previous order details before adding new ones
      if(metadataDisplay) {
        metadataDisplay.innerHTML = '';
      }
  
      if (!orderNumber) {
        alert('Please enter a valid order number.');
        return;
      }

      const ipAddress = await getIpAddress();
  
      try {
        // Replace with your actual Shopify API call logic
        const response = await fetch('https://us-east5-order-status-tracking-447120.cloudfunctions.net/order-status-fetcher', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ 
            orderId: "name:" + orderNumber,
            ipAddress: ipAddress,
            submittedEmail: submittedEmail,
          }),
        });
  
        if (!response.ok) {
          throw new Error(`Error fetching order details. Status: ${response.status}`);
        }
  
        const dataRes = await response.json();
        const data = dataRes.shopifyResponse;
        const aftershipData = dataRes.aftershipResponse;
        let isThereAftershipData = false;

        const emailOnFile = data.data.orders.edges[0].node.email;

        function createOrderComponents(aftershipData = []) {
          if(emailOnFile === null || emailOnFile.toLowerCase() === submittedEmail.toLowerCase()) {
            if (data && data.data && data.data.orders && data.data.orders.edges[0]) {
              const correctOrder = ["status_shipped", "status_packaged", "status_painted", "status_prepared", "status_ordered"];
              const initialMetafields = data.data.orders.edges[0].node.metafields.nodes;
              const metafields = initialMetafields.sort((a, b) => correctOrder.indexOf(a.key) - correctOrder.indexOf(b.key));
              const lineItemsEdges = data.data.orders.edges[0].node.lineItems.edges;
              const fulfillments = data.data.orders.edges[0].node.fulfillments;
              const tags = data.data.orders.edges[0].node.tags;
              let localPickup = false;
              let collapseAccordion = false;

              if(tags.length > 0) {
                for(let i = 0; i < tags.length; i++) {
                  if(tags[i] === "Local") {
                    localPickup = true;
                    break;
                  }
                }
              }


              let lineItems = [];
              let fulfilledSkus = [];
              let trackingNumber;
              let shippingCompany;
              let partiallyFulfilled = false;

              //At least one shipment has taken place. There is a potential for partially fulfilled here though
              if(fulfillments.length === 1) {
                //The skus of all the items that have shipped
                let shippedSkus = data.data.orders.edges[0].node.fulfillments[0].order.fulfillments[0].fulfillmentLineItems.edges;
                const trackingInfo = data.data.orders.edges[0].node.fulfillments[0].trackingInfo[0];

                shippedSkus.forEach((edge) => {
                  let shippedSku = edge.node.lineItem.sku;
                  if(aftershipData[0]?.data?.tracking?.tag === "InTransit" || aftershipData[0]?.data?.tracking?.tag === "OutForDelivery" || aftershipData[0]?.data?.tracking?.tag === "Delivered") {
                    trackingNumber = trackingInfo.number;
                  }
                  let trackingCompany = trackingInfo.company;
                  fulfilledSkus.push({
                    'shippedSku': shippedSku,
                    'trackingNumber': trackingNumber,
                    'trackingCompany': trackingCompany,
                  });
                })

                //Total number of items in order--needed to check to see if partially fulfilled
                const totalItemsInOrder = data.data.orders.edges[0].node.lineItems.edges;
                if(totalItemsInOrder.length !== fulfilledSkus.length) {
                  //Partially fulfilled order
                  partiallyFulfilled = true;
                }
              
                shippingCompany = trackingInfo.company;
              }

              //Multiple shipments have taken place.  It is already partially fulfilled, but there could still be some that have not shipped
              if(fulfillments.length > 1) {
                const localFulfillments = data.data.orders.edges[0].node.fulfillments;

                //Each fulfillment will have it's own tracking number
                for (let fulfillment of localFulfillments) {
                  const localTrackingNumber = fulfillment.trackingInfo[0].number;
                  if(fulfillment.status.toLowerCase().includes('cancel')) continue;

                  let orderFulfillments = fulfillment.order.fulfillments;

                  //Each order will have all items on order so need to ensure that the ones with the same tracking number are pushed
                  for (let order of orderFulfillments) {
                    const orderTrackingNumber = order.trackingInfo[0].number;
                    // This is where we ensure that the correct sku is being pushed with the correct tracking number
                    if(orderTrackingNumber === localTrackingNumber) {
                      let shippedSkus = order.fulfillmentLineItems.edges;
                      let trackingInfo = order.trackingInfo[0];

                      for (let edge of shippedSkus) {

                        let shippedSku = edge.node.lineItem.sku;
                        for (let data of aftershipData) {
                          if(data?.data?.tracking?.tracking_number === trackingInfo.number) {
                            if(data?.data?.tracking?.tag === "InTransit" || data?.data?.tracking?.tag === "OutForDelivery" || data?.data?.tracking?.tag === "Delivered") {
                              trackingNumber = trackingInfo.number;
                            }

                            let trackingCompany = trackingInfo.company;
                            fulfilledSkus.push({
                              'shippedSku': shippedSku,
                              'trackingNumber': trackingNumber,
                              'trackingCompany': trackingCompany,
                            });
                          }
                        }
                      }

                      break;
                    }
                  }
                }
              }


                document.getElementById('order-details').style.display = 'flex';

                // Group metafields by rawKey
                const metafieldGroups = {};
                const skuGroups = {};
                const skusWithStatus = [];
        
                // For those products that actually have a status other than production_status
                metafields.forEach((edge) => {
                  const rawValue = edge.value;
                  const rawKey = edge.key;
        
                  try {
                    if (rawKey !== "production_status" && rawKey !== "status_mixed") {
                      const parsedArray = JSON.parse(rawValue);
                      if (Array.isArray(parsedArray)) {
                        parsedArray.forEach((metafieldValue) => {
                          const [code, timestamp] = metafieldValue.split('_');
                          //Some codes do not have a sku so therefore the code returns an empty string
                          if(code.length > 0) {
                            skusWithStatus.push(code);
                            // Group by rawKey
                            if (!metafieldGroups[rawKey]) {
                              metafieldGroups[rawKey] = [];
                            }
                            metafieldGroups[rawKey].push({ code, timestamp });
                            if(!skuGroups[code]) {
                              skuGroups[code] = [];
                            }
                            skuGroups[code].push({ rawKey, timestamp });
                          }
                        });
                      } else {
                        console.log('Unexpected metafield format:', rawValue);
                      }
                    }
                  } catch (error) {
                    console.error('Error parsing metafield value:', rawValue, error);
                  }
                });
        
                // Clear previous content in orderDetails before appending new data
                if(orderDetails) {
                  orderDetails.innerHTML = '<h2>Order Details</h2>';
                }

                // Some orders will have removed items that get refunded
                // Must check if those exist, and if they do, remove them from the lineItems array

                // First, push all lineItems into an array for easy searching
                lineItemsEdges.forEach((edge) => {
                  let rawValue = edge.node.sku;
                  lineItems.push(rawValue);
                });


                // Push all the refunded skus into an array if they are present
                let refundedSkus = [];
                if(data.data.orders.edges[0]?.node?.refunds?.length) {
                  let refunds = data.data.orders.edges[0].node.refunds
                  refunds.forEach((refund) => {
                    if(refund.refundLineItems.edges.length > 0) {

                      let refundedSku = refund.refundLineItems.edges[0].node.lineItem.sku;


                      refundedSkus.push(refundedSku);
                    }
                  })
                }


                // If there has been refunds, remove them from the lineItems array
                if(refundedSkus.length > 0) {
                  for(let i = 0; i < refundedSkus.length; i++) {
                    let currentRefundedSku = refundedSkus[i];

                    let index = lineItems.indexOf(currentRefundedSku);
                    // If the item is found, remove it from the array
                    if (index !== -1) {
                      lineItems.splice(index, 1); // Removes the item at the found index
                    }
                  }
                }

                // If there are no more lineItems at this point, then that means the entire order has been cancelled
                if(lineItems.length === 0) {
                  document.getElementById('order-details').style.display = 'flex';
                  document.getElementById('order-details').style.justifyContent = 'center';
                  document.getElementById('order-details').style.alignItems = 'center';
                  
                  if (orderDetails) {
                    orderDetails.innerHTML = 'This order has been cancelled.';
                    orderDetails.style.padding = '1rem 1.5rem';
                    orderDetails.style.background = 'white';
                    orderDetails.style.borderRadius = '12px';
                    orderDetails.style.boxShadow = '0px 4px 12px rgba(0, 0, 0, 0.1)';
                    orderDetails.style.textAlign = 'center';
                    orderDetails.style.color = '#555';
                    orderDetails.style.fontSize = '1rem';
                    orderDetails.style.maxWidth = '400px';
                    orderDetails.style.margin = '16px auto';
                  }

                  button.classList.remove("button--loading");
                  button.disabled = false;
                  buttonText.style.display = "inline-block";
                  
                  return;
                }


                // Some orders may have multiple items in different status stages.
                // This is used to compare the number of items in the order to the items that have a status.
                // If some items do not have a status, a skuGroup is created for them and status_ordered is pushed
                // If items do have a status, then status_orderd is pushed to the existing skuGroup
                // There should always be the same number of skuGroups as lineItems
                lineItems.forEach((rawValue) => {
                  if(rawValue.includes('.')) {
                    rawValue = rawValue.split('.')[0];
                  }

                  if(!skusWithStatus.includes(rawValue)) {
                    if (!skuGroups[rawValue]) {
                      skuGroups[rawValue] = [];
                    }
                  }
                  skuGroups[rawValue].push({
                    rawKey: 'status_ordered',
                    timestamp: formatDateToLocalTime(data.data.orders.edges[0].node.createdAt),
                  });
                })


                // Create metafield sections dynamically for each individual product in the order
                for (const key of Object.keys(skuGroups)) {
                  let unpainted = false;
                  const sku = lineItemsEdges.find((item) => item.node.sku.split('.')[0] === key).node.sku;
                  const localTrackingInfo = fulfilledSkus.find((item) => {
                    return item.shippedSku === sku;
                  });
                  if(!localTrackingInfo) {
                    isThereAftershipData = false;
                  } else {
                    isThereAftershipData = true;
                  }



                  //If the following is false, continue on in this for loop
                  for (let data of aftershipData) {
                    if(localTrackingInfo?.trackingNumber === data?.data?.tracking?.tracking_number) {
                      const checkpointArr = data?.data?.tracking?.checkpoints;
                      localTrackingInfo.checkpoints = checkpointArr;
                    }
                  }


                  if(sku && !sku.includes(".")) {
                    unpainted = true
                  }


                  const group = skuGroups[key];
        
                  // Create section for each rawKey
                  const metafieldSection = document.createElement('div');
                  metafieldSection.classList.add('metafield');



                  const headerContainer = document.createElement('div');
                  headerContainer.classList.add('order-header-container');

                  const productImage = document.createElement('div');
                  productImage.classList.add('product-image');
                  const imageElement = document.createElement('img');
                  const imageUrl = lineItemsEdges.find((item) => item.node?.sku?.split('.')[0] === key).node.image?.url;
                  if (imageUrl) {
                    imageElement.src = imageUrl;
                    imageElement.alt = "Product Image";
                    productImage.appendChild(imageElement);
                  }

                  const header = document.createElement('div');
                  header.classList.add('order-header');
                  header.textContent = lineItemsEdges.find((item) => item.node.sku.split('.')[0] === key).node.title;

                  headerContainer.appendChild(productImage);
                  headerContainer.appendChild(header);

                  let totalRows;
                  let statusRowMap = {};
                  let skippedStepRowMap = {};
                  let labels = {};
                  let dotLength;
                  let startHeight;
                  let endHeight;

                  // The following is if there is no aftership data. Meaning it is likely still going through the production process
                  if(unpainted && !isThereAftershipData) {
                    totalRows = 3 //Ordered, packed, shipped
                    statusRowMap = {
                      "status_ordered": 2,
                      "status_packaged": 1,
                      "status_shipped": 0,
                    };
                    skippedStepRowMap = {
                      2: "status_ordered",
                      1: "status_packaged",
                      0: "status_shipped",
                    }
                    if(localPickup) {
                      labels = [
                      { message: 'Ready For Pickup', location: null, production: true, status: 'Partify' }, 
                      { message: 'Packaged', location: null, production: true, status: 'Partify' },
                      { message: 'Ordered', location: null, production: true, status: 'Partify' },
                      ];
                    } else {
                      labels = [
                        { message: 'Awaiting Courier', location: null, production: true, status: 'Partify' }, 
                        { message: 'Packaged', location: null, production: true, status: 'Partify' },
                        { message: 'Ordered', location: null, production: true, status: 'Partify' },
                      ];
                    }
                    dotLength = 3;
                  // The following is if there is aftership data and unpainted, meaning it is in transit
                  } else if(unpainted && isThereAftershipData) {
                    collapseAccordion = true;
                    let productionRows = 3; //Ordered, packed, awaiting courier
                    let initialCheckpointCounter = -1;
                    let shippingSoon = true;
                    labels = [
                      { message: 'Awaiting Courier', location: null, production: true, status: 'Partify' }, 
                      { message: 'Packaged', location: null, production: true, status: 'Partify' },
                      { message: 'Ordered', location: null, production: true, status: 'Partify' },
                    ];

                    let originalCheckpointsArr;

                    originalCheckpointsArr = localTrackingInfo?.checkpoints;
                    let onlyNeededCheckpoints = 0;
                    originalCheckpointsArr.forEach((checkpoint, i) => {
                      if (i === 0) return;
                      if(checkpoint.tag !== "InTransit" && checkpoint.tag !== "OutForDelivery" && checkpoint.tag !== "Delivered") return;
                      onlyNeededCheckpoints++;
                    })

                    let orderedIdx = 2 + onlyNeededCheckpoints;
                    let packagedIdx = 1 + onlyNeededCheckpoints;
                    let shippedIdx = 0 + onlyNeededCheckpoints;
                    statusRowMap = {
                      "status_ordered": orderedIdx,
                      "status_packaged": packagedIdx,
                      "status_shipped": shippedIdx,
                    };
                    skippedStepRowMap = {
                      orderedIdx: "status_ordered",
                      packagedIdx: "status_packaged",
                      shippedIdx: "status_shipped",
                    }


                    // Find the last index of "InTransit" or "OutForDelivery"
                    let latestIndexTransit = -1;
                    let latestIndexOutForDelivery = -1;

                    originalCheckpointsArr.forEach((checkpoint, i) => {
                      if (checkpoint.tag === "InTransit") {
                        latestIndexTransit = i;
                      }
                      if (checkpoint.tag === "OutForDelivery") {
                        latestIndexOutForDelivery = i;
                      }
                    });

                    originalCheckpointsArr.forEach((checkpoint, i) => {
                      if (i === 0) return;
                      if(checkpoint.tag !== "InTransit" && checkpoint.tag !== "OutForDelivery" && checkpoint.tag !== "Delivered") return;
                      productionRows++;

                      if(checkpoint.tag === "InTransit") {
                        labels.unshift({
                          message: checkpoint.message,
                          location: checkpoint.location || null,
                          production: latestIndexTransit === i,
                          status: checkpoint.tag
                        });
                      }

                      if(checkpoint.tag === "OutForDelivery") {
                        labels.unshift({
                          message: checkpoint.message,
                          location: checkpoint.location || null,
                          production: latestIndexOutForDelivery === i,
                          status: checkpoint.tag
                        });
                      }

                      if(checkpoint.tag === "Delivered") {
                        labels.unshift({
                          message: checkpoint.message,
                          location: checkpoint.location || null,
                          production: true,
                          status: checkpoint.tag
                        });
                      }

                        statusRowMap[`status_checkpoint${i}`] = initialCheckpointCounter + onlyNeededCheckpoints;
                        group.unshift({
                          rawKey: `status_checkpoint${i}`,
                          timestamp: formatDateToLocalTime(checkpoint.checkpoint_time),
                        });

                      initialCheckpointCounter--;
                    });
                    dotLength = productionRows;

                  // The following is a painted product that has not been shipped yet, in other words, no aftership data on it yet
                  } else if(!unpainted && !isThereAftershipData) {
                    totalRows = 5 //Ordered, prepped, painted, packed, shipped
                    statusRowMap = {
                      "status_ordered": 4,
                      "status_prepared": 3,
                      "status_painted": 2,
                      "status_packaged": 1,
                      "status_shipped": 0,
                    };
                    skippedStepRowMap = {
                      4: "status_ordered",
                      3: "status_prepared",
                      2: "status_painted",
                      1: "status_packaged",
                      0: "status_shipped",
                    }
                    if(localPickup) {
                      labels = [
                        { message: 'Ready For Pickup', location: null, production: true, status: 'Partify' }, 
                        { message: 'Packaged', location: null, production: true, status: 'Partify' },
                        { message: 'Painted', location: null, production: true, status: 'Partify' },
                        { message: 'Prepped For Painting', location: null, production: true, status: 'Partify' },
                        { message: 'Ordered', location: null, production: true, status: 'Partify' },
                      ];
                      
                    } else {
                      labels = [
                        { message: 'Awaiting Courier', location: null, production: true, status: 'Partify' }, 
                        { message: 'Packaged', location: null, production: true, status: 'Partify' },
                        { message: 'Painted', location: null, production: true, status: 'Partify' },
                        { message: 'Prepped For Painting', location: null, production: true, status: 'Partify'},
                        { message: 'Ordered', location: null, production: true, status: 'Partify' },
                      ];
                    }
                    dotLength = 5;

                  // The only remaining condition-- painted product that has been shipped
                  } else {
                    collapseAccordion = true;
                    let productionRows = 5; //Ordered, prepped, painted, packed, awaiting courier
                    let initialCheckpointCounter = -1;
                    let shippingSoon = true;
                    labels = [
                      { message: 'Awaiting Courier', location: null, production: true, status: 'Partify' }, 
                      { message: 'Packaged', location: null, production: true, status: 'Partify' },
                      { message: 'Painted', location: null, production: true, status: 'Partify' },
                      { message: 'Prepped For Painting', location: null, production: true, status: 'Partify' },
                      { message: 'Ordered', location: null, production: true, status: 'Partify' },
                    ];

                    const originalCheckpointsArr = localTrackingInfo?.checkpoints;
                    let onlyNeededCheckpoints = 0;
                    originalCheckpointsArr.forEach((checkpoint, i) => {
                      if (i === 0) return;
                      if(checkpoint.tag !== "InTransit" && checkpoint.tag !== "OutForDelivery" && checkpoint.tag !== "Delivered") return;
                      onlyNeededCheckpoints++;
                    })

                    let orderedIdx = 4 + onlyNeededCheckpoints;
                    let preppedIdx = 3 + onlyNeededCheckpoints;
                    let paintedIdx = 2 + onlyNeededCheckpoints;
                    let packagedIdx = 1 + onlyNeededCheckpoints;
                    let shippedIdx = 0 + onlyNeededCheckpoints;
                    statusRowMap = {
                      "status_ordered": orderedIdx,
                      "status_prepared": preppedIdx,
                      "status_painted": paintedIdx,
                      "status_packaged": packagedIdx,
                      "status_shipped": shippedIdx,
                    };
                    skippedStepRowMap = {
                      orderedIdx: "status_ordered",
                      preppedIdx: "status_prepared",
                      paintedIdx: "status_painted",
                      packagedIdx: "status_packaged",
                      shippedIdx: "status_shipped",
                    }


                    // Find the last index of "InTransit" or "OutForDelivery"
                      let latestIndexTransit = -1;
                      let latestIndexOutForDelivery = -1;

                      originalCheckpointsArr.forEach((checkpoint, i) => {
                        if (checkpoint.tag === "InTransit") {
                          latestIndexTransit = i;
                        }
                        if (checkpoint.tag === "OutForDelivery") {
                          latestIndexOutForDelivery = i;
                        }
                      });

                    originalCheckpointsArr.forEach((checkpoint, i) => {
                      if (i === 0) return;
                      if(checkpoint.tag !== "InTransit" && checkpoint.tag !== "OutForDelivery" && checkpoint.tag !== "Delivered") return;
                      productionRows++;

                      if(checkpoint.tag === "InTransit") {
                        labels.unshift({
                          message: checkpoint.message,
                          location: checkpoint.location || null,
                          production: latestIndexTransit === i,
                          status: checkpoint.tag
                        });
                      }

                      if(checkpoint.tag === "OutForDelivery") {
                        labels.unshift({
                          message: checkpoint.message,
                          location: checkpoint.location || null,
                          production: latestIndexOutForDelivery === i,
                          status: checkpoint.tag
                        });
                      }

                      if(checkpoint.tag === "Delivered") {
                        labels.unshift({
                          message: checkpoint.message,
                          location: checkpoint.location || null,
                          production: true,
                          status: checkpoint.tag
                        });
                      }

                        statusRowMap[`status_checkpoint${i}`] = initialCheckpointCounter + onlyNeededCheckpoints;
                        group.unshift({
                          rawKey: `status_checkpoint${i}`,
                          timestamp: formatDateToLocalTime(checkpoint.checkpoint_time),
                        });

                      initialCheckpointCounter--;
                    });


                    dotLength = productionRows;
                  }

        
                  const rows = Array(Object.keys(statusRowMap).length).fill(null);

                  let scanChecker = false; //Used to determine the latest status update
                  let prevIndexOfRawKey = 0; //Initiates to shipped
                  let prevDateTime = 0;
                  let recursiveCounter = 0;



                  // Iterate through the group and populate the rows array
                  group.forEach((item) => {
                    const index = statusRowMap[item.rawKey];


                    function createDateTimeHTML() {
                      const codeP = document.createElement('p');
                      codeP.classList.add('code-p');
                      let date = item.timestamp.split(' ')[2];
                      let time = item.timestamp.split(' ')[0] + ' ' + item.timestamp.split(' ')[1];
                      if(time.startsWith('0')) {
                        time = time.substring(1);
                      }
                      codeP.innerHTML = `<span>${date}</span><br><p>${time}</p>`;
                      rows[index] = codeP;
                    }

                    //If scan checker is false, then the first rawKey is the latest status update
                    if(!scanChecker) {
                      prevIndexOfRawKey = index;
                      scanChecker = true;
                      prevDateTime = Date.parse(item.timestamp);

                      createDateTimeHTML();
                    } else {
                      //Because scan checker is now true, the index should always only ever be 1 more than the previous index. 
                      //If it is not, then there was a scan that was skipped
                      let difference = index - prevIndexOfRawKey;

                      if (difference !== 1) {
                        function recursiveChecker() {
                          let skippedRawKey = skippedStepRowMap[prevIndexOfRawKey + 1];

                          const codeP = document.createElement('p');
                          codeP.classList.add('code-p');
                          const twoHours = 1000 * 60 * 60 * 2; //1000 ms in a sec * 60 sec * 60 min * 2 for 2 hours;
                          const dummyTime = prevDateTime + twoHours; //in milliseconds
                          prevDateTime = dummyTime;
                          const formattedNewTime = formatDateTimeFromMS(dummyTime);
                          
                          let date = formattedNewTime.split(' ')[0];
                          let time = formattedNewTime.split(' ')[1] + ' ' + item.timestamp.split(' ')[2];
                          if(time.startsWith('0')) {
                            time = time.substring(1);
                          }
                          codeP.innerHTML = `<span>Completed</span>`;
                          
                          prevIndexOfRawKey++;
                          
                          rows[prevIndexOfRawKey] = codeP;
                          let newDifference = index - prevIndexOfRawKey;

                          if(recursiveCounter < 5) {
                            if(newDifference === 1) {
                              createDateTimeHTML();
                              prevIndexOfRawKey++;
                            } else if(newDifference !== 0) {
                              recursiveCounter++;
                              recursiveChecker();
                            }
                          }
                        }
                        recursiveChecker();
                      } else {
                        prevIndexOfRawKey = index;
                        createDateTimeHTML();
                      }
                    }
                  });

                  const orderStatusTracker = document.createElement('div');
                  orderStatusTracker.id = 'order-status-tracker';

                  filledDotCounter = 0;

                  let allRowContainers = [];
                  let presentLabels = [];
                  const statusTags = {
                    'InTransit': "In Transit",
                    'OutForDelivery': "Out For Delivery",
                    'Delivered': 'Delivered'
                  };

                 // Making the divs and other containers for the displayed content
                    rows.forEach((row, index) => {
                      const rowContainer = document.createElement('div');
                      rowContainer.classList.add('row');
                      rowContainer.style.display = 'grid';
                      rowContainer.style.gridTemplateColumns = '1fr minmax(30px, auto) 1fr'; // Ensure the row maintains 3 columns
                      rowContainer.style.alignItems = 'center';
                      rowContainer.style.padding = '10px 0';

                      // left column
                      const codeContainer = document.createElement('div');
                      codeContainer.classList.add('code-container');
                      const codeP = row || document.createElement('p');
                      codeP.classList.add('code-p');
                      if (!row) {
                        codeP.innerHTML = `<span style="font-weight: 500;">Pending Completion</span><br><p style="font-size: 14px">TBD</p>`;
                      }
                      codeContainer.appendChild(codeP);
                      rowContainer.appendChild(codeContainer);


                      // Middle Column (Status Dot)
                      const dotContainer = document.createElement('div');
                      dotContainer.classList.add('dot-container'); // New wrapper for centering
                      dotContainer.style.display = 'flex';
                      dotContainer.style.justifyContent = 'center';
                      dotContainer.style.alignItems = 'center';


                      const dot = document.createElement('span');
                      dot.classList.add('dot');
                      if (rows[index] !== null) {
                        dot.classList.add('filled');
                        filledDotCounter++;
                      }
                      dotContainer.appendChild(dot); // Append dot to the new container
                      rowContainer.appendChild(dotContainer); 


                      // Right Column (Status Label)
                      const statusLabel = document.createElement('span');
                      statusLabel.classList.add('status-label');
                      
                      // Only show unique labels
                      let rowMessageCollapsed;
                      let rowMessageExpanded;

                        if(labels[index].status === "Partify") {
                          rowMessageCollapsed = labels[index].message;
                        } else {
                          rowMessageCollapsed = statusTags[labels[index].status];
                        }

                      rowMessageExpanded = labels[index].message;

                        if(!presentLabels.includes(rowMessageCollapsed)) {
                          let messageToDisplay = collapseAccordion ? rowMessageCollapsed : rowMessageExpanded; // Use the right message

                          if(rows[index] !== null) {
                            if (labels[index].location) {
                              statusLabel.innerHTML = `<span>${messageToDisplay}</span><br><p>${labels[index].location}</p>`;
                            } else {
                              if(codeP.innerHTML.includes("Pending Completion")) {
                                statusLabel.innerHTML = `<span style="font-weight: 500;">${messageToDisplay}</span>`;
                              } else {
                                statusLabel.innerHTML = `<span>${messageToDisplay}</span>`;
                              }
                            }
                          } else {
                            if (labels[index].location) {
                              statusLabel.innerHTML = `<span>${messageToDisplay}</span><br><p>${labels[index].location}</p>`;
                            } else {
                              if(codeP.innerHTML.includes("Pending Completion")) {
                                statusLabel.innerHTML = `<span style="font-weight: 500;">${messageToDisplay}</span>`;
                              } else {
                                statusLabel.innerHTML = `<span>${messageToDisplay}</span>`;
                              }
                            }
                          }
                          presentLabels.push(rowMessageCollapsed);
                        }


                      rowContainer.appendChild(statusLabel);

                      allRowContainers.push({
                        row: rowContainer,
                        production: labels[index].production, 
                        status: labels[index].status,
                        labelElement: statusLabel,  // Store reference to label element
                        expandedMessage: rowMessageExpanded,
                        collapsedMessage: rowMessageCollapsed,
                        location: labels[index].location
                      });

                      if(!collapseAccordion) {
                        orderStatusTracker.appendChild(rowContainer);
                      } else {
                        orderStatusTracker.appendChild(rowContainer);
                        rowContainer.style.display = 'none';
                      }
                    });


                  const statusLine = document.createElement('div');
                  statusLine.classList.add('status-line');

                  document.documentElement.style.setProperty('--row-count', dotLength);

                  // Set a CSS variable to control the colored line height
                  if (unpainted) {
                    metafieldSection.style.gridTemplateRows = 'repeat(3, auto)';
                  } else {
                    metafieldSection.style.gridTemplateRows = 'repeat(5, auto)';
                  }

                  let varForStartHeight = 100 / (dotLength - 1);

                  if(unpainted) {
                    endHeight = ((filledDotCounter / (dotLength - 1)) * 100);
                    startHeight = (((filledDotCounter / (dotLength - 1)) * 100) - varForStartHeight);
                  } else {
                    endHeight = ((filledDotCounter / (dotLength - 1)) * 100);
                    startHeight = (((filledDotCounter / (dotLength - 1)) * 100) - varForStartHeight); // Convert to percentage
                  }

                  if(startHeight < 0) {
                    startHeight = 0;
                  }
                  if(endHeight < 0) {
                    endHeight = 0;
                  }
                  const currentStatus = 100 - startHeight;
                  const nextStatus = 100 - endHeight;
                  // Set the height variables for animation
                  statusLine.style.setProperty('--filled-height-start', `${currentStatus}%`);
                  statusLine.style.setProperty('--filled-height-end', `${nextStatus}%`);
                  statusLine.style.setProperty('--filled-height', `${currentStatus}%`);

                  // Activate the "pending" animation effect
                  statusLine.classList.add('pending');


                  const orderContainer = document.createElement('div');
                  orderContainer.classList.add('order-container');

                  const wrapperDiv = document.createElement('div');
                  wrapperDiv.classList.add('status-tracker-metafield-wrapper');


                  // Expand for more details section
                  const expandForDetailsContainer = document.createElement('div');
                  expandForDetailsContainer.classList.add('expand-for-details-container');
                  expandForDetailsContainer.innerHTML = `<p>Expand For Details</p>`;

                  // Initialize the details as just the first and last index visible if collapseAccordion is true
                  if(collapseAccordion) {
                    allRowContainers.forEach((container, index) => {
                      container.row.style.display = index === 0 || container.production === true ? 'grid' : 'none';
                    });
                  }
                  
                  let initialRenderForCollapse = true;
                  let isCollapsed;

                  // The following event listener is for expanding and collapsing the accordion
                  expandForDetailsContainer.addEventListener('click', () => {
                    if(initialRenderForCollapse) {
                      isCollapsed = true;
                      initialRenderForCollapse = false;
                    }
                  
                    if (isCollapsed) {
                      // Expand: Show all rows smoothly
                      allRowContainers.forEach(container => {
                        container.row.style.display = 'grid';  // Ensure grid layout stays intact
                        container.row.style.opacity = '0';  // Start from invisible
                        container.row.style.transition = 'max-height 0.4s ease-out, opacity 0.4s ease-out';
                        container.row.style.maxHeight = container.row.scrollHeight + 'px'; // Smooth expand
                        setTimeout(() => container.row.style.opacity = '1', 50); // Fade-in effect

                        if (container.location) {
                          container.labelElement.innerHTML = `<span>${container.expandedMessage}</span><br><p>${container.location}</p>`;
                        } else {
                          container.labelElement.innerHTML = `<span>${container.expandedMessage}</span>`;
                        }
                      });
                      isCollapsed = false;
                      expandForDetailsContainer.innerHTML = `<p>Collapse Details</p>`;
                    } else {

                      // Collapse: Hide all except first and last smoothly
                      allRowContainers.forEach((container, index) => {
                        if (index !== 0 && container.production === false) {
                          container.row.style.transition = 'max-height 0.4s ease-in, opacity 0.4s ease-in';
                          container.row.style.maxHeight = '0px';  // Smooth collapse
                          container.row.style.opacity = '0'; // Fade-out effect
                          setTimeout(() => {
                            container.row.style.display = 'none'; // Hide after animation
                          }, 400); 
                        }

                        if (container.location) {
                          container.labelElement.innerHTML = `<span>${container.collapsedMessage}</span><br><p>${container.location}</p>`;
                        } else {
                          container.labelElement.innerHTML = `<span>${container.collapsedMessage}</span>`;
                        }
                      });
                      isCollapsed = true;
                      expandForDetailsContainer.innerHTML = `<p>Expand Details</p>`;

                      const offset = 200; // Pixels above the orderContainer
                      const elementPosition = orderContainer.getBoundingClientRect().top + window.scrollY;
                      window.scrollTo({ top: elementPosition - offset, behavior: 'smooth' });
                    }
                  });
                  
                  



                  // Append the three main components to the order container
                  orderContainer.appendChild(headerContainer);
                  if(presentLabels.includes("In Transit") || presentLabels.includes("Out For Delivery") || presentLabels.includes("Delivered")) {
                    orderContainer.appendChild(expandForDetailsContainer);
                  }
                  orderContainer.appendChild(wrapperDiv);


                  wrapperDiv.appendChild(orderStatusTracker); 
                  orderStatusTracker.appendChild(statusLine);


                  orderDetails.appendChild(orderContainer);
                };
            } else {
              document.getElementById('order-details').style.display = 'flex';
              document.getElementById('order-details').style.justifyContent = 'center';
              document.getElementById('order-details').style.alignItems = 'center';
              
              if (orderDetails) {
                orderDetails.innerHTML = 'Order not found.';
                orderDetails.style.padding = '1rem 1.5rem';
                orderDetails.style.background = 'white';
                orderDetails.style.borderRadius = '12px';
                orderDetails.style.boxShadow = '0px 4px 12px rgba(0, 0, 0, 0.1)';
                orderDetails.style.textAlign = 'center';
                orderDetails.style.color = '#555';
                orderDetails.style.fontSize = '1rem';
                orderDetails.style.maxWidth = '400px';
                orderDetails.style.margin = '16px auto';
              }
            }
          } else {
            document.getElementById('order-details').style.display = 'flex';
            document.getElementById('order-details').style.justifyContent = 'center';
            document.getElementById('order-details').style.alignItems = 'center';
            
            if (orderDetails) {
              orderDetails.innerHTML = 'The email provided does not match our records for this order.';
              orderDetails.style.padding = '1rem 1.5rem';
              orderDetails.style.background = 'white';
              orderDetails.style.borderRadius = '12px';
              orderDetails.style.boxShadow = '0px 4px 12px rgba(0, 0, 0, 0.1)';
              orderDetails.style.textAlign = 'center';
              orderDetails.style.color = '#555';
              orderDetails.style.fontSize = '1rem';
              orderDetails.style.maxWidth = '400px';
              orderDetails.style.margin = '16px auto';
            }
          }
        }

        if (aftershipData.length) {
          createOrderComponents(aftershipData)
        } else {
          createOrderComponents()
        }
      } catch (error) {
        document.getElementById('order-details').style.display = 'flex';
        document.getElementById('order-details').style.justifyContent = 'center';
        document.getElementById('order-details').style.alignItems = 'center';

        console.error('Error fetching order details: ', error);
        
        if (orderDetails) {
          orderDetails.innerHTML = 'Error fetching order details.';
          orderDetails.style.padding = '1rem 1.5rem';
          orderDetails.style.background = 'white';
          orderDetails.style.borderRadius = '12px';
          orderDetails.style.boxShadow = '0px 4px 12px rgba(0, 0, 0, 0.1)';
          orderDetails.style.textAlign = 'center';
          orderDetails.style.color = '#555';
          orderDetails.style.fontSize = '1rem';
          orderDetails.style.maxWidth = '400px';
          orderDetails.style.margin = '16px auto';
        }
      }
      button.classList.remove("button--loading");
      buttonText.style.display = "inline-block";
    });
  });
</script>