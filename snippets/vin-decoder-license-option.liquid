  </div>
  <div class="license-decoder-failed-attempt" style="display: none;">
    {{ 'fitment_verification.failed_attempt_vin' | t }}
  </div>
  <div class="license-decoder-remaining-attempts" style="display: none;">
    {{ 'fitment_verification.remaining_attempts' | t }}
  </div>
  <div class="license-decoder-fetching-license-data" style="display: none;">
    {{ 'fitment_verification.fetching_vin_data' | t }}
  </div>
  <div class="license-decoder-submission-failed-message" style="display: none;">
    {{ 'vin_decoder_product_page.failed_3_times_message' | t }}
  </div>
  <div class="license-decoder-submission-success-message" style="display: none;">
    {{ 'fitment_verification.success' | t }}
  </div>
  <button type="button" class="license-decoder-submit-btn" id="license-decoder-submit-btn" disabled>Submit</button>
</div>

<script>
  document.addEventListener('DOMContentLoaded', async function() {
      const garageSearchTerms = getGarageSearchTerms();
      const licenseDecoderPlateInput = document.getElementById('license-decoder-plate-input');

      licenseDecoderPlateInput.addEventListener('input', async function (event) {
          handleLicenseChange(event, 1, '{{ 'garage.enter_valid_characters' | t }}', 'license-decoder-submit-btn');
      });
  });

  // Add loading spinner logic and VIN submission to license-decoder-submit-btn
  const noResultsLicenseDecoder = '{{ 'garage.no_results' | t }}';
  const searchBtnLicenseDecoder = '{{ 'garage.search_btn' | t }}';
  const tailoredSuccessMessageLicenseDecoder = '{{ 'fitment_verification.tailored_success_message' | t }}';
  const failedAttemptLicenseDecoder = '{{ 'fitment_verification.failed_attempt_license' | t }}';
  const remainingAttemptsLicenseDecoder = '{{ 'fitment_verification.remaining_attempts' | t }}';
  const failed3timesmsgLicenseDecoder = '{{ 'vin_decoder.failed_3_times_msg' | t }}';
  const vinDecoderFirstMsgLicenseDecoder = '{{ 'vin_decoder_product_page.first_license' | t }}';
  const vinDecoderEndMsgLicenseDecoder = '{{ 'vin_decoder_product_page.end' | t }}';
  const forceSelectMsgStartLicenseDecoder = '{{ 'vin_decoder_product_page.force_select_first_license' | t }}';
  const forceSelectMsgEndLicenseDecoder = '{{ 'vin_decoder_product_page.force_select_second' | t }}';
  const licenseDecoderSubmitBtn = document.querySelector('.license-decoder-submit-btn');

  if (licenseDecoderSubmitBtn) {
      licenseDecoderSubmitBtn.addEventListener('click', async function() {
          if (licenseDecoderSubmitBtn.disabled || licenseDecoderSubmitBtn.classList.contains('license-decoder-submit-btn--loading')) return;
          const licenseInputElem = document.getElementById('license-decoder-plate-input');
          const licenseInput = licenseInputElem.value.trim().toUpperCase();
          const stateSelect = document.getElementById('license-decoder-state-select');
          const state = stateSelect ? stateSelect.value : '';
          // Remove spaces and trim the plate input
          const plate = licenseInput ? licenseInput.replace(/\s+/g, '').trim() : '';
          licenseDecoderSubmitBtn._originalText = licenseDecoderSubmitBtn.textContent;
          licenseDecoderSubmitBtn.textContent = '';
          licenseDecoderSubmitBtn.classList.add('license-decoder-submit-btn--loading');
          const troublesomeMakesColors = {};
          let isBumperdotcom = '{{ is_bumperdotcom_make_found }}' === 'true';
          let isTroublesomeMake = '{{ is_troublesome_make }}' === 'true';
          {% if is_troublesome_make == true or is_troublesome_make == 'true'%}
              {% assign product_variants = product.variants %}
              {% assign variant_count = product_variants | size %}
              {% if variant_count > 0 %}
                  {% for variant in product_variants %}
                      {% if variant.metafields.custom.chromedata_reference %}
                          troublesomeMakesColors[{{ variant.metafields.custom.chromedata_reference }}] = '{{ variant.title }}';
                      {% endif %}
                  {% endfor %}
              {% endif %}
          {% endif %}
          // Submission logic moved here
          attemptedDecodedLicensePlates.push(licenseInput);
          try {
              const data = await fetchBumpersLicenseToVin(state, plate);
              const vinInput = data.vin ? data.vin.toUpperCase() : '';

              const isLicenseValidWithPaintCode = await handleVinDecode(
                vinInput,
                state,
                plate,
                4,
                troublesomeMakesColors,
                isBumperdotcom,
                failed3timesmsgLicenseDecoder,
                noResultsLicenseDecoder,
                searchBtnLicenseDecoder,
                tailoredSuccessMessageLicenseDecoder,
                failedAttemptLicenseDecoder,
                remainingAttemptsLicenseDecoder,
                vinDecoderFirstMsgLicenseDecoder,
                vinDecoderEndMsgLicenseDecoder,
                forceSelectMsgStartLicenseDecoder,
                forceSelectMsgEndLicenseDecoder
              );
              if (isLicenseValidWithPaintCode) {
                isLicenseDecoderExhausted = true;
                {% comment %} resortToForceSelectCode();
                formulateForcePaintCodeSelectMsg('', plate, forceSelectMsgStartLicenseDecoder, forceSelectMsgEndLicenseDecoder, 4); {% endcomment %}
                {% comment %} hidePaintCodeAppContainerLicense(false, false); {% endcomment %}
              }
          } catch (error) {
              console.error('Error fetching license data:', error);
              licenseDecoderSubmitBtn.classList.remove('license-decoder-submit-btn--loading');
              licenseDecoderSubmitBtn.textContent = licenseDecoderSubmitBtn._originalText || 'Submit';
              document.querySelector('.license-decoder-submission-failed-message').style.display = 'block';
          } finally {
              // No matter what, enable the button if three license plates have been attempted
              if (attemptedDecodedLicensePlates.length === maxAttempts) {
                  isLicenseDecoderExhausted = true;
                  if (successfulVinDecoding === false) {
                      licenseInputElem.value = '';
                      licenseInputElem.disabled = true;
                      resortToForceSelectCode();
                      formulateForcePaintCodeSelectMsg('', plate, forceSelectMsgStartLicenseDecoder, forceSelectMsgEndLicenseDecoder, 4);
                      hidePaintCodeAppContainerLicense(false, false);
                      disableAddToCartButton();
                  } else {
                      enableAddToCartButton();
                  }
              }

              licenseDecoderSubmitBtn.classList.remove('license-decoder-submit-btn--loading');
              licenseDecoderSubmitBtn.textContent = licenseDecoderSubmitBtn._originalText || 'Submit';
              updateProgressHeaderColors();
          }
      });
  }
</script>
