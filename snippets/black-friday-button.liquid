    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const button = document.getElementById("black-friday-button");
            const table = document.getElementById("black-friday-table");
        
            button.addEventListener("click", function(event) {
                event.preventDefault();
                table.scrollIntoView({
                    behavior: "smooth",
                    block: "center" 
                });
            });
        });
    </script>
    