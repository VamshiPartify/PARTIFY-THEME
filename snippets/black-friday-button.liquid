<style>
    .black-friday-button {
        display: inline-block;
        background: #000000;
        color: #fff;
        font-weight: bold;
        font-size: 20px;
        text-decoration: none;
        padding: 16px 24px;
        border-radius: 6px;
        transition: all 0.3s ease;
        text-align: center;
        width: 100%;
        position: relative;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
        margin-bottom: 10px;
    }
    
    .black-friday-button span.highlight {
        color: #ff0000;
        font-size: 22px;
        font-weight: 800;
    }
    
    .black-friday-button:hover {
        transform: translateY(-2px);
        {% comment %} box-shadow: 0 6px 12px rgba(0, 0, 0, 0.3); {% endcomment %}
    }
    
    .black-friday-button:active {
        transform: translateY(0);
    }

    .black-friday-button .cursor {
        display: inline-block;
        width: 20px;
        height: 20px;
        margin-left: 10px;
        position: relative;
        top: 3px;
        animation: click-animation 1s infinite;
    }
    
    /* Click Animation */
    @keyframes click-animation {
        0% {
            transform: scale(1);
        }
        30% {
            transform: scale(0.9); /* Simulates "click" */
        }
        60% {
            transform: scale(1.1); /* Slight overshoot for effect */
        }
        100% {
            transform: scale(1);
        }
    }
    </style>
    
    {% if cart.item_count == 0 %}
        <a href="#black-friday-table" class="black-friday-button" id="black-friday-button">
            Cyber Monday Deals - Click To Learn More!
