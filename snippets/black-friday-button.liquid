                </svg>
            </a>
        {% else %}
            {% assign savings = 150 %}
            <a href="#black-friday-table" class="black-friday-button" id="black-friday-button">
                Congratulations! You're eligible for <span class="highlight">$150</span> off your order!
                <svg class="cursor" stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 512 512" height="200px" width="200px" xmlns="http://www.w3.org/2000/svg">
