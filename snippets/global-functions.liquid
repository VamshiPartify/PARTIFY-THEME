<script>
    window.hideShopifyChat = () => {
        const shopifyChat = document.getElementById('shopify-chat');
        if (shopifyChat) {
          shopifyChat.style.display = 'none';
        }
      }
    
    window.showShopifyChat = () => {
      const shopifyChat = document.getElementById('shopify-chat');
      if (shopifyChat) {
        shopifyChat.style.display = 'block';
      }
    }
</script>