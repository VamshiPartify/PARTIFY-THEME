<style>
  .vin-decoder-message {
    padding: 10px;
    border: 1px solid #007600;
    border-radius: 5px;
    background-color: #f4f9f4;
    margin-top: 10px;
    margin-bottom: 10px;
    font-size: 14px;
    line-height: 1.5;
  }

  .vin-decoder-remaining-attempts {
      color: #e61b24;
      font-size: 14px;
      padding: 2px 0;
  }

  .vin-decoder-fetching-vin-data,
  .vin-decoder-submission-failed-message {
      background-color: #ffbc2c17;
      font-size: 16px;
      font-weight: 500;
      margin-top: 5px;
      text-align: left;
      color: #4b4b4b;
      line-height: 1.2;
      padding: 5px;
      border-left: 4px solid #ffae00;
      border-top: 1px solid #ffae00;
      border-bottom: 1px solid #ffae00;
      border-right: 1px solid #ffae00;
      border-radius: 5px;
  }

  .vin-decoder-submission-success-message {
      background-color: #f4f9f4;
      font-size: 16px;
      font-weight: 500;
      margin-top: 5px;
      text-align: left;
      color: #4b4b4b;
      line-height: 1.2;
      padding: 5px;
      border-left: 4px solid #007600;
      border-top: 1px solid #007600;
      border-bottom: 1px solid #007600;
      border-right: 1px solid #007600;
      border-radius: 5px;
  }

  #vin-decoder-textbox-for-verification {
      width: 100%;
      {% comment %} margin-top: 10px; {% endcomment %}
      padding: 10px;
      border: 1px solid #ddd;
      border-radius: 4px;
      height: 45px;
      margin-top: 2px;
  }

  #vin-decoder-textbox-for-verification:disabled {
      background-color: #f0f0f0;
      color: #ccc;
      cursor: no-drop;
      opacity: 0.6;
  }

  #vin-decoder-textbox-for-verification-wrapper {
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      transition: max-height 0.3s ease, opacity 0.3s ease, margin-top 0.3s ease;
  }

  #vin-decoder-textbox-for-verification-wrapper.show {
      {% comment %} max-height: 100px; /* adjust based on content height */ {% endcomment %}
      opacity: 1;
      margin-top: 10px;
      max-height: fit-content;
  }

  .stored-vin-message {
    color:#444444;
    font-size: 14px;
  }

  .vin-decoder-submit-btn {
    background-color: #007bff;
    color: white;
    border: none;
    padding: 10px 20px;
    border-radius: 4px;
    cursor: pointer;
    min-width: 90px;
    min-height: 40px;
    text-align: center;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    font-size: 14px;
    margin-top: 10px;
  }
  .vin-decoder-submit-btn:disabled {
    background-color: #334FB4;
    color: white;
    border: none;
    border-radius: 4px;
    cursor: no-drop;
    min-height: 40px;
    opacity: 0.7;
  }
  .vin-decoder-submit-btn--loading::after {
    content: "";
    position: absolute;
    width: 16px;
    height: 16px;
    border: 4px solid transparent;
    border-top-color: #ffffff;
    border-radius: 50%;
    animation: button-loading-spinner 1s ease infinite;
  }
  @keyframes button-loading-spinner {
    from { transform: rotate(0turn); }
    to { transform: rotate(1turn); }
  }
</style>

{% assign makes_list = settings.makes_list | split: ', ' %}
{% assign bumperdotcom_makes = settings.bumperdotcom_makes_list | split: ', ' %}
{% assign troublesome_makes = settings.troublesome_chromedata_makes_list | split: ', ' %}
{% assign is_makes_found = false %}
{% assign is_excluded_make_found = false %}
{% assign is_bumperdotcom_make_found = false %}
{% assign is_troublesome_make = false %}
{% assign downcase_handle = product.handle | downcase %}

{% for make in makes_list %}
  {% if downcase_handle contains make %}
    {% assign is_makes_found = true %}
    {% break %}
  {% endif %}
{% endfor %}
{% for bumperdotcom_make in bumperdotcom_makes %}
  {% if downcase_handle contains bumperdotcom_make %}
    {% assign is_bumperdotcom_make_found = true %}
    {% break %}
  {% endif %}
{% endfor %}
{% for troublesome_make in troublesome_makes %}
  {% if downcase_handle contains troublesome_make %}
    {% assign is_troublesome_make = true %}
    {% break %}
  {% endif %}
{% endfor %}

<!--
  is_makes_found means chromedata, bumper is bumper.com, and troublesome is chromedata... so if none of this, then set it to excluded
-->
{% unless is_makes_found == true or is_bumperdotcom_make_found == true or is_troublesome_make == true %}
  {% assign is_excluded_make_found = true %}
{% endunless %}

<div id="vin-decoder-textbox-for-verification-wrapper show">
  <div class="stored-vin-message" style="display: none;"></div>
  <input
    type="text"
    id="vin-decoder-textbox-for-verification"
    placeholder="Enter your VIN"
    maxlength="17"
    name="properties[Fitment Verification]"
    value=""
    {% comment %} disabled {% endcomment %}
  >
  <div class="vin-decoder-remaining-attempts" style="display: none;">
    {{ 'fitment_verification.remaining_attempts' | t }}
  </div>
  <div class="vin-decoder-fetching-vin-data" style="display: none;">
    {{ 'fitment_verification.fetching_vin_data' | t }}
  </div>
  <div class="vin-decoder-submission-failed-message" style="display: none;">
    {{ 'vin_decoder_product_page.failed_3_times_message' | t }}
  </div>
  <div class="vin-decoder-submission-success-message" style="display: none;">
    {{ 'fitment_verification.success' | t }}
  </div>
  <button type="button" class="vin-decoder-submit-btn" disabled>Submit</button>
</div>

<script>
  document.addEventListener('DOMContentLoaded', async function() {
    const garageSearchTerms = getGarageSearchTerms();

    document.getElementById('vin-decoder-textbox-for-verification').addEventListener('input', async function (event) {
      const originalValue = event.target.value;
      const troublesomeMakesColors = {};

      let isExcludedValue = '{{ is_excluded_make_found }}';
      let isBumperdotcom = '{{ is_bumperdotcom_make_found }}' === 'true';
      let isTroublesomeMake = '{{ is_troublesome_make }}' === 'true';

      {% if is_troublesome_make == true or is_troublesome_make == 'true'%}
        {% assign product_variants = product.variants %}
          {% assign variant_count = product_variants | size %}
              
          {% if variant_count > 0 %}
              {% for variant in product_variants %}
              {% if variant.metafields.custom.chromedata_reference %}
                      troublesomeMakesColors[{{ variant.metafields.custom.chromedata_reference }}] = '{{ variant.title }}';
              {% endif %}
              {% endfor %}
        {% endif %}
      {% endif %}
      

      let vinInput = originalValue.toUpperCase();
      const isRetryed = handleVinChange(event, 3, '{{ 'garage.enter_valid_characters' | t }}');
      if (isRetryed) {
        return;
      }
      const filteredValue = vinInput.replace(/[IOQ\s:;()!@#$%^?'"&*\-_=+.`~<>{}\[\]|,\/\\]/gi, '');
      // Set sanitized value to input box
      event.target.value = filteredValue;
      vinInput = filteredValue;
      if (vinInput !== filteredValue) {
        alert('Please enter valid characters. I, O, Q and special characters are not allowed in VINs');
      } else if (typeof warning !== 'undefined') {
        warning.style.display = 'none';
      }
      // Enable/disable submit button based on VIN length
      if (vinSubmitBtn) {
        vinSubmitBtn.disabled = vinInput.length !== 17;
      }
      // Only handle UI feedback here, not submission
      if (vinInput.length === 0) {
        enableAddToCartButton();
      } else if (vinInput.length < 17) {
        currentAddToCartBtn.disabled = true;
      }
      updateProgressHeaderColors();
    });
  });

    async function handleVinDecode(vinInput, location, troublesomeMakesColors, bumperdotcommake, failed3timesmsg) {
        let searchTerms = getGarageSearchTerms();  
        const noResults = '{{ 'garage.no_results' | t }}';
        const searchBtn = '{{ 'garage.search_btn' | t }}';
        const tailoredSuccessMessage = '{{ 'fitment_verification.tailored_success_message' | t }}';
        const remainingAttempts = '{{ 'fitment_verification.remaining_attempts' | t }}';
        let exteriorColor = '';

        // Returns isVinValid and Paint code (if no paint code, returns empty string)
        const { validVin, ymm, paintCode } = await fetchVehicalDataByVin(vinInput, location, noResults, failed3timesmsg, searchBtn, tailoredSuccessMessage, remainingAttempts, troublesomeMakesColors, bumperdotcommake);
        console.log('validVin', validVin);
        console.log('paintCode', paintCode);
        console.log('ymm here', ymm);

        if(validVin) {
            // Vin is valid and paint code is found
            handleAutoSelectColor(paintCode, vinInput);
            searchTerms[0].vin = vinInput;
            if(paintCode !== '') {
              if (Array.isArray(searchTerms) && searchTerms.length > 0) {
                const firstYMM = searchTerms[0].ymm || '';
                if(firstYMM === ymm) {
                  searchTerms[0].paintCode = paintCode;
                }
              }
            }
            localStorage.setItem('searchTerms', JSON.stringify(searchTerms));
            window.GarageLogic.updateGaragePopup(window.GarageUtils.getSearchTerms());
        } else {
            // Vin is not valid
        }
        updateProgressHeaderColors();

    }

    function handleAutoSelectColor(paintCode, vinInput) {
        // Reference: Vin-Decoder-app.liquid auto-select logic
        const paintCodeWrapper = document.querySelector('.paint-code-wrapper');
        const variantSelector = document.getElementById('variant-selector');
        let matchingOption = false;

        if (variantSelector) {
            const options = Array.from(variantSelector.options);
            options.find(option => {
                if(option.label.split(" ")[0] === paintCode) {
                    matchingOption = true;
                    if(option.textContent.includes("🚚")) {
                        decodedVINHasAvailableStock = true;
                    }
                    autoSelectedColor = option.value;
                    autoSelectedOption = option;
                    return true;
                }
            });

            if (matchingOption) {
                storedDecodedVin = vinInput;
                if(autoSelectedOption.dataset.unavailable === 'true') {
                    autoSelectedBanned = true;
                }
                variantSelector.value = autoSelectedColor;
                document.body.classList.remove('no-scroll-paint-swatch');
                if(enablePrepaintedMessaging) {
                    if (decodedVINHasAvailableStock) {
                        if(typeof showPaintedStockKeyPaintDisclaimer === 'function') {
                            showPaintedStockKeyPaintDisclaimer();
                        }
                    }
                }
                if(!autoSelectedBanned) {
                    // Create a new message to indicate the selected VIN
                    const vinMessage = document.createElement('div');
                    vinMessage.className = 'vin-decoder-message';
                    vinMessage.style.display = 'block';
                    vinMessage.innerHTML = `
                        <strong style="color: #444;">{{ 'vin_decoder_product_page.first' | t }}</strong>
                        <span style="color: #000; font-weight: 800;">${vinInput},</span>
                        <span style="color: #444;">{{ 'vin_decoder_product_page.end' | t }}</span>
                        <span style="color: #000; font-weight: 800;">${paintCode}</span>
                    `;
                    if(paintCodeWrapper) paintCodeWrapper.appendChild(vinMessage);
                }
                // Trigger the change event programmatically
                variantSelector.dispatchEvent(new Event('change', { bubbles: true }));
            } else {
                boolMatchByVIN = true;
                handleMatchByVin(vinInput, true);
                handleFormulateVinMessage(vinInput);
                console.warn(`No matching option found for paint code: ${paintCode}`);
            }
        } else {
            console.warn('Variant selector dropdown not found.');
        }
        if(paintCodeWrapper) paintCodeWrapper.classList.add('show');
        const paintCodeAppContainer = document.getElementById('paintcode-app-container');
        if(paintCodeAppContainer) paintCodeAppContainer.classList.remove('show');
    }

    function handleMatchByVin(vinInput, boolMatchByVIN) {
        // Reference: resortToGetPaintCodeByVin
        const combinedVariantSelect = document.getElementById('variant-selector');
        const vin = vinInput;
        let hiddenDiv;
        storedDecodedVin = vin;

        if (typeof vinTextBoxOEMLibrary !== 'undefined' && vinTextBoxOEMLibrary && vinTextBoxOEMLibrary.value.length) {
            vinTextBoxOEMLibrary.value = "";
            if (typeof hideVINTextboxForOEM === 'function') hideVINTextboxForOEM();
        }

        if (typeof amountOfVINPostMessages === 'undefined') {
            amountOfVINPostMessages = 0;
        }
        if (amountOfVINPostMessages > 0 && boolMatchByVIN === false) {
            return;
        }


        if (document.querySelector('.hidden-vin-option')) {
            hiddenDiv = document.querySelector('.hidden-vin-option');
        } else if (document.querySelector('.hidden-vin-option-single-quality')) {
            hiddenDiv = document.querySelector('.hidden-vin-option-single-quality');
        }

        // Only display the option to select Match Paint by VIN in certain circumstances
        if (boolMatchByVIN) {
            if (hiddenDiv) {
                if (!combinedVariantSelect) {
                    console.error("Error: Select element not found.");
                    return;
                }

                let value;
                if (hiddenDiv.getAttribute("data-value")) {
                    value = hiddenDiv.getAttribute("data-value");
                } else if (hiddenDiv.getAttribute("value")) {
                    value = hiddenDiv.getAttribute("value");
                }

                const text = hiddenDiv.textContent;
                const price = hiddenDiv.getAttribute("data-price") || "";
                const priceDifference = hiddenDiv.getAttribute("data-price-difference") || "";
                const color = hiddenDiv.getAttribute("data-color") || "";
                const variantTitle = hiddenDiv.getAttribute("data-variant-title") || "";
                const productTitle = hiddenDiv.getAttribute("data-product-title") || "";
                const variantSKU = hiddenDiv.getAttribute("data-variant-sku") || "";
                const option = document.createElement("option");

                option.value = value;
                option.textContent = text;
                option.setAttribute("data-price", price);
                option.setAttribute("data-price-difference", priceDifference);
                option.setAttribute("data-color", color);
                option.setAttribute("data-variant-title", variantTitle);
                option.setAttribute("data-product-title", productTitle);
                option.setAttribute("data-variant-sku", variantSKU);

                option.classList.add("hidden-vin-option");

                // Append and remove
                combinedVariantSelect.appendChild(option);
                hiddenDiv.remove();
            }
        }
        amountOfVINPostMessages++;
    }

    function handleFormulateVinMessage(vin) {
        // Reference: formulateMessage
        const variantSelector = document.getElementById('variant-selector');
        const paintCodeWrapper = document.querySelector('.paint-code-wrapper');
        // Optional: update OEM VIN textbox and container if present
        if (typeof oemVinContainerLibrary !== 'undefined' && oemVinContainerLibrary && oemVinContainerLibrary.style.display === "block") {
            if (typeof vinTextBoxOEMLibrary !== 'undefined' && vinTextBoxOEMLibrary) {
                vinTextBoxOEMLibrary.value = '';
            }
            oemVinContainerLibrary.style.display = "none";
            const productTypeDropdown = oemVinContainerLibrary.closest('.product-type-dropdown');
            if (productTypeDropdown) {
                const nextDivider = productTypeDropdown.nextElementSibling;
                if (nextDivider && nextDivider.classList.contains('divider')) {
                    nextDivider.style.display = 'none';
                }
            }
        }
        // Optional: update VIN input if present
        if (typeof vinInputLibrary !== 'undefined' && vinInputLibrary) {
            vinInputLibrary.value = vin;
        }
        if (variantSelector) {
            const options = Array.from(variantSelector.options);
            options.find(option => {
                if(option.label.startsWith("Match Paint by VIN") || option.label.startsWith("Pintura de combinación por VIN")) {
                    // Show the VIN textbox container if present
                    if (typeof vinTextboxContainer !== 'undefined' && vinTextboxContainer) {
                        vinTextboxContainer.style.display = "block";
                        // Remove any existing message to avoid duplication
                        const existingMessage = vinTextboxContainer.querySelector('.vin-selected-message');
                        if (existingMessage) {
                            existingMessage.remove();
                        }
                        // Create a new message to indicate the selected VIN
                        const vinMessage = document.createElement('div');
                        vinMessage.className = 'vin-decoder-message vin-selected-message';
                        vinMessage.style.display = 'block';
                        vinMessage.innerHTML = `
                            <strong style=\"color: #444;\">{{ 'vin_decoder_product_page.auto_attach_msg_strong' | t }}</strong> 
                            <span style=\"color: #000; font-weight: 800;\">${vin}</span> 
                            <span style=\"color: #444;\">{{ 'vin_decoder_product_page.will_be_attached' | t }}</span> 
                            <span style=\"color: #444; font-weight: bold;\">{{ 'vin_decoder_product_page.bold' | t }}</span> 
                            <span style=\"color: #444;\">{{ 'vin_decoder_product_page.for_this_item' | t }}</span>
                        `;
                        paintCodeWrapper.appendChild(vinMessage);
                    }
                    variantSelector.value = option.value;
                    document.body.classList.remove('no-scroll-paint-swatch');
                    variantSelector.dispatchEvent(new Event('change', { bubbles: true }));
                    return true;
                }
            });
        } else {
            console.warn('Variant selector dropdown not found.');
        }
    }

    // Add loading spinner logic and VIN submission to vin-decoder-submit-btn
    const vinSubmitBtn = document.querySelector('.vin-decoder-submit-btn');
    if (vinSubmitBtn) {
      vinSubmitBtn.addEventListener('click', async function() {
        if (vinSubmitBtn.disabled || vinSubmitBtn.classList.contains('vin-decoder-submit-btn--loading')) return;
        const vinInputElem = document.getElementById('vin-decoder-textbox-for-verification');
        const vinInput = vinInputElem.value.trim().toUpperCase();
        if (vinInput.length !== 17) {
          alert('VIN must be exactly 17 characters.');
          return;
        }
        vinSubmitBtn._originalText = vinSubmitBtn.textContent;
        vinSubmitBtn.textContent = '';
        vinSubmitBtn.classList.add('vin-decoder-submit-btn--loading');
        const troublesomeMakesColors = {};
        let isBumperdotcom = '{{ is_bumperdotcom_make_found }}' === 'true';
        let isTroublesomeMake = '{{ is_troublesome_make }}' === 'true';
        {% if is_troublesome_make == true or is_troublesome_make == 'true'%}
          {% assign product_variants = product.variants %}
            {% assign variant_count = product_variants | size %}
            {% if variant_count > 0 %}
                {% for variant in product_variants %}
                {% if variant.metafields.custom.chromedata_reference %}
                        troublesomeMakesColors[{{ variant.metafields.custom.chromedata_reference }}] = '{{ variant.title }}';
                {% endif %}
                {% endfor %}
          {% endif %}
        {% endif %}
        // Submission logic moved here
        attemptedDecodedVins.push(vinInput);
        const failed3timesmsg = '{{ 'vin_decoder.failed_3_times_msg' | t }}';
        await handleVinDecode(vinInput, 3, troublesomeMakesColors, isBumperdotcom, failed3timesmsg);
        // No matter what, enable the button if three vins have been attempted
        if (attemptedDecodedVins.length === 3) {
          if (successfulVinDecoding === false) {
            vinInputElem.value = '';
            vinInputElem.disabled = true;
            disableAddToCartButton();
          } else {
            enableAddToCartButton();
          }
        }
        vinSubmitBtn.classList.remove('vin-decoder-submit-btn--loading');
        vinSubmitBtn.textContent = vinSubmitBtn._originalText || 'Submit';
        updateProgressHeaderColors();
      });
    }
</script>
