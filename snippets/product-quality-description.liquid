      background-color: #063175;
    }
  }

  /* Desktop */
  @media only screen and (min-width: 451px) {
    .quality-popup-container {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 5000;
      overflow-y: auto;
    }
    .quality-popup-modal {
      position: relative;
      width: 60%; /* Adjusted width for desktop */
      max-width: 800px; /* Limit maximum width */
      background-color: white;
      margin: 5% auto; /* Center modal vertically and horizontally */
      padding: 30px;
      box-shadow: 0 0 20px rgba(0, 0, 0, 0.5);
      animation: drop-in 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      z-index: 9999;
      border-radius: 8px;
    }
    .quality-popup-modal img {
      max-width: 100%;
      height: auto;
      display: block;
      margin: 0 auto;
    }
    .quality-popup-modal h1 {
      font-size: 28px;
      margin-bottom: 15px;
      text-align: center;
