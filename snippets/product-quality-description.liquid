      text-align: left; /* Align text to left */
      cursor: pointer;
      transition: background-color 0.3s ease;
    }
    #quality-modal-button:hover {
      background-color: #063175;
    }
  }

  @keyframes drop-in {
    0% { opacity: 0; transform: translateY(-50px); }
    100% { opacity: 1; transform: translateY(0); }
  }
</style>

<button id="quality-modal-button" class="btn">How To Find Your Paint Code</button>

<div class="product-quality-popup-dark-overlay"></div>

<div class="quality-popup-container">
  <div class="quality-popup-modal">
    <button id="modal-exit">&#x2715;</button>
    <h1>How To Find Your Paint Code</h1>
    <div class="popup-modal-content">
      <!-- Placeholder for dynamically inserted content -->
    </div>
  </div>
</div>

<script>
  const showOverlay = () => document.querySelector(".product-quality-popup-dark-overlay").style.display = "block";
  const showModal = (content) => {
    const modalContent = document.querySelector(".popup-modal-content");
    modalContent.innerHTML = content;
    document.querySelector(".quality-popup-container").style.display = "block";
  };
  const hideOverlay = () => document.querySelector(".product-quality-popup-dark-overlay").style.display = "none";
  const hideModal = () => document.querySelector(".quality-popup-container").style.display = "none";

  // Function to fetch content from Shopify page using Liquid
  const fetchPageContent = async () => {
    try {
      const response = await fetch('{{ product.metafields.custom.qualitydetailsurl | escape }}.json');
      if (!response.ok) {
        throw new Error('Failed to fetch content');
      }
      const data = await response.json();
      return data;
    } catch (error) {
      console.error('Fetch error:', error);
      throw error;
    }
  };

  // Open Modal
  document.querySelector("#quality-modal-button").onclick = async function(){
    showOverlay();
    try {
      const pageContent = await fetchPageContent();
      showModal(pageContent.page.body_html); // Assuming the content is in the body_html of the page
    } catch (error) {
      console.error('Error fetching page content:', error);
    }
  };

  // Close Modal
  document.getElementById("modal-exit").onclick = function(){
    hideOverlay();
    hideModal();
  };

  window.onclick = function(event) {
    if(event.target === document.querySelector('.quality-popup-container')){
      hideOverlay();
      hideModal();
    }
  };
</script> {% endcomment %}
