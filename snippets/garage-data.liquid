<script>
  // This script is now obselete!!!!














  /*
      This script manages the storage of recent search terms in localStorage for a collection page.
      - Checks if the current template is 'collection'.
      - Compares the current collection title with the last stored search term and ensures it's not null.
      - Validates that the collection title starts with four digits and contains at least three words.
      - Initializes the 'searchTerms' array in localStorage if it doesn't exist.
      - Adds the new search term to the beginning of the array if it's not already present.
      - Limits the stored search terms to the five most recent entries.
      - Updates localStorage with the new array of search terms.
  */
    if('{{ template.name }}' === 'collection') {
        if({{ collection.title | json }} !== localStorage.getItem("searchTerms") && {{ collection.title | json }} !== null) {
            let newSearchTerm = {{ collection.title | json }};

        //The /^\d{4}/.test(newSearchTerm) enforces the first four characters are numbers
        //The .split(' ') enforces that there are at least three words
            if (/^\d{4}/.test(newSearchTerm)) {
                if (newSearchTerm.split(' ').length >= 3) {
                    if(localStorage.getItem("searchTerms") == null) {
                        localStorage.setItem("searchTerms", "[]");
                    }

                    let oldSearchTerms = JSON.parse(localStorage.getItem("searchTerms")) || [];
                  // Migrate if old format
                  if (oldSearchTerms.length && typeof oldSearchTerms[0] === "string") {
                    oldSearchTerms = oldSearchTerms.map(ymm =>
                    typeof ymm === "string"
                        ? { ymm, vin: null, paintCode: null }
                        : ymm
                    );
                  }

                  oldSearchTerms = oldSearchTerms.map(entry => {
                      // If entry.ymm is an object, flatten it
                      if (entry && typeof entry.ymm === 'object' && entry.ymm !== null) {
                          entry = {
                            ymm: entry.ymm.ymm,
                            vin: entry.ymm.vin,
                            paintCode: entry.ymm.paintCode,
                            year: entry.ymm.year,
                            make: entry.ymm.make,
                            model: entry.ymm.model,
                            submodel: entry.ymm.submodel,
                            engine: entry.ymm.engine
                        };
                      }
                    return {
                        ymm: entry.ymm,
                        vin: entry.vin || null,
                        paintCode: entry.paintCode || null,
                        year: entry.year || null,
                        make: entry.make || null,
                        model: entry.model || null,
                        submodel: entry.submodel || null,
                        engine: entry.engine || null
                    };
                  });
                  localStorage.setItem('searchTerms', JSON.stringify(oldSearchTerms));
                  if (!oldSearchTerms.some(obj => obj.ymm === newSearchTerm)) {
                    // Get VIN from URL if present
                    const urlParams = new URLSearchParams(window.location.search);
                    const vinFromUrl = urlParams.get('vin') || null;

                    oldSearchTerms.unshift({
                        ymm: newSearchTerm,
                        vin: vinFromUrl,
                        paintCode: null,
                        year: null,
                        make: null,
                        model: null,
                        submodel: null,
                        engine: null
                    });
                    if (oldSearchTerms.length > 5) {
                          oldSearchTerms.pop();
                    }
                    localStorage.setItem("searchTerms", JSON.stringify(oldSearchTerms));
                  }
                }
            }
        }
    }
</script>
