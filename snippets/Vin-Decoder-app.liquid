<style>
  .vin-decoder-message {
    padding: 10px;
    border: 1px solid #007600;
    border-radius: 5px;
    background-color: #f4f9f4;
    margin-top: 10px;
    margin-bottom: 10px;
    font-size: 14px;
    line-height: 1.5;
  }
</style>

<div>
  {% assign makes_list = settings.makes_list | split: ', ' %}
  {% comment %} {% assign excluded_makes = settings.excluded_makes_list | split: ", " %} {% endcomment %}
  {% assign bumperdotcom_makes = settings.bumperdotcom_makes_list | split: ', ' %}
  {% assign troublesome_makes = settings.troublesome_chromedata_makes_list | split: ', ' %}
  {% assign is_makes_found = false %}
  {% assign is_excluded_make_found = false %}
  {% assign is_bumperdotcom_make_found = false %}
  {% assign is_troublesome_make = false %}
  {% assign downcase_handle = product.handle | downcase %}

  {% for make in makes_list %}
    {% if downcase_handle contains make %}
      {% assign is_makes_found = true %}
      {% break %}
    {% endif %}
  {% endfor %}
  {% comment %}
    {% for excluded_make in excluded_makes %}
        {% if downcase_handle contains excluded_make %}
            {% assign is_excluded_make_found = true %}
            {% break %}
        {% endif %}
    {% endfor %}
  {% endcomment %}
  {% for bumperdotcom_make in bumperdotcom_makes %}
    {% if downcase_handle contains bumperdotcom_make %}
      {% assign is_bumperdotcom_make_found = true %}
      {% break %}
    {% endif %}
  {% endfor %}
  {% for troublesome_make in troublesome_makes %}
    {% if downcase_handle contains troublesome_make %}
      {% assign is_troublesome_make = true %}
      {% break %}
    {% endif %}
  {% endfor %}

  <!--
    is_makes_found means chromedata, bumper is bumper.com, and troublesome is chromedata... so if none of this, then set it to excluded
  -->
  {% unless is_makes_found == true or is_bumperdotcom_make_found == true or is_troublesome_make == true %}
    {% assign is_excluded_make_found = true %}
  {% endunless %}

  <div id="product-details-for-app" data-product-title="{{ product.title }}" data-product-id="{{ product.id }}"></div>

  <iframe
    id="paintcode-iframe"
    src="https://vin-to-paintcode-app-445858330997.us-east5.run.app"
    style="width: 100%; height: 100%; min-height: 225px; border: none;"
    scrolling="no"
    allowfullscreen
    sandbox="allow-forms allow-scripts allow-same-origin allow-popups allow-modals"
  >
  </iframe>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const iframe = document.getElementById('paintcode-iframe');
        const parentUrl = window.location.href;
        const productDetailsElement = document.getElementById('product-details-for-app');
        const paintCodeWrapper = document.querySelector(".paint-code-wrapper");
        const paintCodeAppContainer = document.getElementById('paintcode-app-container');
        const paintOptionsCheckboxGroup = document.querySelector('.paint-options-checkbox-group');
        const troublesomeMakesColors = {};
        let updatePaintCodeHandled = false;

        let isExcludedValue = '{{ is_excluded_make_found }}';
        let isBumperdotcom = '{{ is_bumperdotcom_make_found }}';

        {% if is_troublesome_make == true %}
          {% assign product_variants = product.variants %}
            {% assign variant_count = product_variants | size %}
            
            {% if variant_count > 0 %}
                {% for variant in product_variants %}
                {% if variant.metafields.custom.chromedata_reference %}
                    troublesomeMakesColors[{{ variant.metafields.custom.chromedata_reference }}] = '{{ variant.title }}';
                {% endif %}
                {% endfor %}
          {% endif %}
        {% endif %}

          window.addEventListener('message', async function(event) {
            if (event.data.type === 'iframeReady') {
                getIpAddress().then(ipAddress => {
                    iframe.contentWindow.postMessage(
                        {
                            type: 'productPage',
                            url: parentUrl,
                            makeExcluded: isExcludedValue,
                            bumperdotcomMake: isBumperdotcom,
                            ipAddress: ipAddress,
                            troublesomeMakesColors: troublesomeMakesColors,
                            themeName: themeName
                        },
                        'https://vin-to-paintcode-app-445858330997.us-east5.run.app'
                    );
                }).catch(error => {
                    console.error('Error in getIpAddress:', error);
                });
            }
        });

        window.addEventListener('message', async function(event) {
            if (event.data.type === 'iframeReady') {
                iframe.contentWindow.postMessage(
                    {
                        type: 'language',
                        locale: '{{ shop.locale }}'
                    },
                    'https://vin-to-paintcode-app-445858330997.us-east5.run.app'
                );
            }
        });
        
        window.addEventListener('message', function(event) {
            if (event.origin === 'https://vin-to-paintcode-app-445858330997.us-east5.run.app') {
                if (event.data.type === 'resizeIframe') {

                    // Adjust the iframe's height based on the received data
                    iframe.style.height = event.data.height + 50 + 'px';
                }

              //Automatically select the color in the variant-selector dropdown
                if (event.data.type === "updatePaintCode") {
                  // Hide any force-select VIN message if present
                  const forceSelectMsg = document.querySelector('.vin-decoder-message.resort-to-force-select');
                  if (forceSelectMsg) {
                    forceSelectMsg.style.display = 'none';
                  }
                  vinDecoderJustUsed = true;
                  const paintCode = event.data.paintCode ? event.data.paintCode.replace(/-/g, '') : '';
                  const vinSelected = event.data.vin;
                  const paintCodeWrapper = document.querySelector('.paint-code-wrapper');
                  const variantSelector = document.getElementById('variant-selector');

                  let matchingOption = false;

                  // Product page component library variable
                  storedDecodedVin = vinSelected;

                    if (variantSelector) {
                        {% comment %} if(!failedVinDecode) hideGetPaintCodeUsingVINCheckbox(); {% endcomment %}
                        
                        const options = Array.from(variantSelector.options);
                        options.find(option => {
                            if(option.label.split(" ")[0] === paintCode) {
                                matchingOption = true;
                                if(option.textContent.includes("🚚")) {
                                  decodedVINHasAvailableStock = true;
                                }

                                // Product page component library variable
                                autoSelectedColor = option.value;
                                autoSelectedOption = option;
                                return;
                            }
                        });
    
                        if (matchingOption) {
                          if(autoSelectedOption.dataset.unavailable === 'true') {
                            autoSelectedBanned = true;
                          };
                            variantSelector.value = autoSelectedColor;
                            document.body.classList.remove('no-scroll-paint-swatch');
                            if(window.enablePrepaintedMessaging) {
                              if (decodedVINHasAvailableStock) {
                                showPaintedStockKeyPaintDisclaimer();
                              }
                            }

                            if(!autoSelectedBanned) {
                              
                              // Create a new message to indicate the selected VIN
                              const vinMessage = document.createElement('div');
                              vinMessage.className = 'vin-decoder-message';
                              vinMessage.style.display = 'block';
                              vinMessage.innerHTML = `
                              <strong style="color: #444;">{{ 'vin_decoder_product_page.first' | t }}</strong>
                              <span style="color: #000; font-weight: 800;">${vinSelected},</span>
                              <span style="color: #444;">{{ 'vin_decoder_product_page.end' | t }}</span>
                              <span style="color: #000; font-weight: 800;">${paintCode}</span> 
                              `;
                          
                              // Append the message to the VIN textbox container
                              paintCodeWrapper.appendChild(vinMessage);
                            }
        
                            // Trigger the change event programmatically
                            variantSelector.dispatchEvent(new Event('change', { bubbles: true }));
                          if (vinInputLibrary) {
                            vinInputLibrary.value = vinSelected;
                          }
                        } else {
                            boolMatchByVIN = true;
                            console.warn(`No matching option found for paint code: ${paintCode}`);
                            const paintCodeWrapper = document.querySelector('.paint-code-wrapper');
                            resortToForceSelectCode();                            
                            formulateMessageForceSelectCode(event.data.vin);

                            paintCodeWrapper.classList.add('show');
                            paintCodeAppContainer.classList.remove('show');
                        }
                    } else {
                        console.warn('Variant selector dropdown not found.');
                    }
                    paintCodeWrapper.classList.add('show');
                    paintCodeAppContainer.classList.remove('show');
                    updatePaintCodeHandled = true;
                    {% comment %} paintOptionsCheckboxGroup.classList.add('hide'); {% endcomment %}
                }

                if (event.data.type === "getPaintByVIN" && !updatePaintCodeHandled) {
                    vinDecoderJustUsed = true;
                    const paintCodeWrapper = document.querySelector('.paint-code-wrapper');

                    {% comment %} resortToGetPaintCodeByVin(event.data.vin, event.data.matchByVIN); {% endcomment %}
                    resortToForceSelectCode();
                    {% comment %} formulateMessageAttachedVin(event.data.vin); {% endcomment %}
                    
                    formulateMessageForceSelectCode(event.data.vin);

                    paintCodeWrapper.classList.add('show');
                    paintCodeAppContainer.classList.remove('show');
                    {% comment %} paintOptionsCheckboxGroup.classList.add('hide'); {% endcomment %}
                }
            }
        });

        async function getIpAddress() {
            try {
              const response = await fetch('https://api.ipify.org?format=json');
              const data = await response.json();
              return data.ip; // Returns the client's public IP
            } catch (error) {
              console.error("Error fetching IP address:", error);
              return null;
            }
        };

        function formulateMessageForceSelectCode(vin) {
            if (combinedVariantSelectLibrary) {
                const options = Array.from(combinedVariantSelectLibrary.options);
                
                if (oemVinContainerLibrary && oemVinContainerLibrary.style.display === "block") {
                    vinTextBoxOEMLibrary.value = '';
                    oemVinContainerLibrary.style.display = "none";

                    const productTypeDropdown = oemVinContainerLibrary.closest('.product-type-dropdown');
                    if (productTypeDropdown) {
                        const nextDivider = productTypeDropdown.nextElementSibling;
                        if (nextDivider && nextDivider.classList.contains('divider')) {
                            nextDivider.style.display = 'none';
                        }
                    }
                }
        
        
                {% comment %} options.find(option => {
                    if(option.label.startsWith("Match Paint by VIN") || option.label.startsWith("Pintura de combinación por VIN")) {         {% endcomment %}
                        if (vinTextboxContainer) {
                            vinTextboxContainer.style.display = "block";
                      
                            // Remove any existing message to avoid duplication
                            const existingMessage = vinTextboxContainer.querySelector('.vin-selected-message');
                            if (existingMessage) {
                              existingMessage.remove();
                            }
                      
                            // Create a new message to indicate the selected VIN
                            const vinMessage = document.createElement('div');
                            vinMessage.className = 'vin-decoder-message resort-to-force-select';
                            vinMessage.style.display = 'block';
                            vinMessage.innerHTML = `
                            <strong style="color: #444;">{{ 'vin_decoder_product_page.force_select_first' | t }}</strong> 
                            <span style="color: #000; font-weight: 800;">${vin}.</span> 
                            <span style="color: #444;">{{ 'vin_decoder_product_page.force_select_second' | t }}</span> 
                            {% comment %} <span style="color: #444; font-weight: bold;">{{ 'vin_decoder_product_page.bold' | t }}</span> 
                            <span style="color: #444;">{{ 'vin_decoder_product_page.for_this_item' | t }}</span> {% endcomment %}
                            `;
                            vinMessage.style.backgroundColor = '#ffbc2c17';
                            vinMessage.style.border = '1px solid #ffae00';
        
                            failedVinDecode = true;
                            {% comment %} if(checkboxGetPaintCodeWithVINAndLabel.style.display === "none") showGetPaintCodeUsingVINCheckbox(); {% endcomment %}

                      
                            // Append the message to the VIN textbox container
                            paintCodeWrapper.appendChild(vinMessage);
                        }                                
                        {% comment %} combinedVariantSelectLibrary.value = option.value; {% endcomment %}
                        document.body.classList.remove('no-scroll-paint-swatch');
                        {% comment %} combinedVariantSelectLibrary.dispatchEvent(new Event('change', { bubbles: true })); {% endcomment %}
        
                        return;
                    {% comment %} }
                });    {% endcomment %}
            } else {
                console.warn('Variant selector dropdown not found.');
            }
        }

        // Reenable the function to formulate the message when attaching VIN
        {% comment %} function formulateMessageAttachedVin(vin) {
            if (combinedVariantSelectLibrary) {
                const options = Array.from(combinedVariantSelectLibrary.options);
                
                if (oemVinContainerLibrary && oemVinContainerLibrary.style.display === "block") {
                    vinTextBoxOEMLibrary.value = '';
                    oemVinContainerLibrary.style.display = "none";

                    const productTypeDropdown = oemVinContainerLibrary.closest('.product-type-dropdown');
                    if (productTypeDropdown) {
                        const nextDivider = productTypeDropdown.nextElementSibling;
                        if (nextDivider && nextDivider.classList.contains('divider')) {
                            nextDivider.style.display = 'none';
                        }
                    }
                }
        
        
                if (vinInputLibrary) {
                    vinInputLibrary.value = vin;
                }
        
                options.find(option => {
                    if(option.label.startsWith("Match Paint by VIN") || option.label.startsWith("Pintura de combinación por VIN")) {        
                        if (vinTextboxContainer) {
                            vinTextboxContainer.style.display = "block";
                      
                            // Remove any existing message to avoid duplication
                            const existingMessage = vinTextboxContainer.querySelector('.vin-selected-message');
                            if (existingMessage) {
                              existingMessage.remove();
                            }
                      
                            // Create a new message to indicate the selected VIN
                            const vinMessage = document.createElement('div');
                            vinMessage.className = 'vin-decoder-message';
                            vinMessage.style.display = 'block';
                            vinMessage.innerHTML = `
                            <strong style="color: #444;">{{ 'vin_decoder_product_page.auto_attach_msg_strong' | t }}</strong> 
                            <span style="color: #000; font-weight: 800;">${vin}</span> 
                            <span style="color: #444;">{{ 'vin_decoder_product_page.will_be_attached' | t }}</span> 
                            <span style="color: #444; font-weight: bold;">{{ 'vin_decoder_product_page.bold' | t }}</span> 
                            <span style="color: #444;">{{ 'vin_decoder_product_page.for_this_item' | t }}</span>
                            `;
        
                            failedVinDecode = true;
                            {% comment %} if(checkboxGetPaintCodeWithVINAndLabel.style.display === "none") showGetPaintCodeUsingVINCheckbox(); {% endcomment %}

                      
                            // Append the message to the VIN textbox container
                            paintCodeWrapper.appendChild(vinMessage);
                        }                                
                        combinedVariantSelectLibrary.value = option.value;
                        document.body.classList.remove('no-scroll-paint-swatch');
                        combinedVariantSelectLibrary.dispatchEvent(new Event('change', { bubbles: true }));
        
                        return;
                    }
                });   
            } else {
                console.warn('Variant selector dropdown not found.');
            }
        } {% endcomment %}
    });
</script>
