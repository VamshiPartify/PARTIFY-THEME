<style>
    #paintcode-app-container {
        position: relative;
        width: 100%;
        {% comment %} margin-top: 30px; {% endcomment %}
    }

    .vin-decoder-message {
        padding: 10px;
        border: 1px solid #007600;
        border-radius: 5px;
        background-color: #f4f9f4;
        margin-top: 10px;
        margin-bottom: 0;
        font-size: 14px;
        line-height: 1.5;
    }
</style>

<div>
    {% assign makes_list = settings.makes_list | split: ", " %}
    {% comment %} {% assign excluded_makes = settings.excluded_makes_list | split: ", " %} {% endcomment %}
    {% assign bumperdotcom_makes = settings.bumperdotcom_makes_list | split: ", " %}
    {% assign troublesome_makes = settings.troublesome_chromedata_makes_list | split: ", " %}
    {% assign is_makes_found = false %}
    {% assign is_excluded_make_found = false %}
    {% assign is_bumperdotcom_make_found = false %}
    {% assign is_troublesome_make = false %}
    {% assign downcase_handle = product.handle | downcase %}


    {% for make in makes_list %}
        {% if downcase_handle contains make %}
            {% assign is_makes_found = true %}
            {% break %}
        {% endif %}
    {% endfor %}
    {% comment %} {% for excluded_make in excluded_makes %}
        {% if downcase_handle contains excluded_make %}
            {% assign is_excluded_make_found = true %}
            {% break %}
        {% endif %}
    {% endfor %} {% endcomment %}
    {% for bumperdotcom_make in bumperdotcom_makes %}
        {% if downcase_handle contains bumperdotcom_make %}
            {% assign is_bumperdotcom_make_found = true %}
            {% break %}
        {% endif %}
      {% endfor %}
    {% for troublesome_make in troublesome_makes %}
        {% if downcase_handle contains troublesome_make %}
            {% assign is_troublesome_make = true %}
            {% break %}
        {% endif %}
    {% endfor %}

    <!-- is_makes_found means chromedata, bumper is bumper.com, and troublesome is chromedata... so if none of this, then set it to excluded-->
    {% unless is_makes_found == true or is_bumperdotcom_make_found == true or is_troublesome_make == true %}
        {% assign is_excluded_make_found = true %}
    {% endunless %}
  
    <div id="product-details-for-app" data-product-title="{{ product.title }}" data-product-id="{{ product.id }}">
    </div>

    <div id="paintcode-app-container">
        <iframe
            id="paintcode-iframe"
            src="https://vin-to-paintcode-app-445858330997.us-east5.run.app"
            style="width: 100%; height: 100%; min-height: 225px; border: none;"
            scrolling="no"
            allowfullscreen
            sandbox="allow-forms allow-scripts allow-same-origin allow-popups allow-modals">
        </iframe>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const iframe = document.getElementById('paintcode-iframe');
        const parentUrl = window.location.href;
        const productDetailsElement = document.getElementById('product-details-for-app');
        let isExcludedValue = '{{ is_excluded_make_found }}';
        let isBumperdotcom = '{{ is_bumperdotcom_make_found }}';
        let amountOfVINPostMessages = 0;
        let boolMatchByVIN = false;
        {% comment %} window.failedVinDecode = false; {% endcomment %}

        const getIpAddress = async () => {
            try {
              const response = await fetch('https://api.ipify.org?format=json');
              const data = await response.json();
              return data.ip; // Returns the client's public IP
            } catch (error) {
              console.error("Error fetching IP address:", error);
              return null;
            }
          };


          {% comment %} Getting the product variants with color names for subarus and other complicated ChromeData searches {% endcomment %}
          const troublesomeMakesColors = {};

        {% if is_troublesome_make == true %}
          {% assign product_variants = product.variants %}
            {% assign variant_count = product_variants | size %}
            
            {% if variant_count > 0 %}
                {% for variant in product_variants %}
                {% if variant.metafields.custom.chromedata_reference %}
                    troublesomeMakesColors[{{ variant.metafields.custom.chromedata_reference }}] = '{{ variant.title }}';
                {% endif %}
                {% endfor %}
          {% endif %}
        {% endif %}

          window.addEventListener('message', async function(event) {
            if (event.data.type === 'iframeReady') {
                getIpAddress().then(ipAddress => {
                    iframe.contentWindow.postMessage(
                        {
                            type: 'productPage',
                            url: parentUrl,
                            makeExcluded: isExcludedValue,
                            bumperdotcomMake: isBumperdotcom,
                            ipAddress: ipAddress,
                            troublesomeMakesColors: troublesomeMakesColors
                        },
                        'https://vin-to-paintcode-app-445858330997.us-east5.run.app'
                    );
                }).catch(error => {
                    console.error('Error in getIpAddress:', error);
                });
            }
        });
        
        // Listen for messages from the iframe
        window.addEventListener('message', function(event) {
            if (event.origin === 'https://vin-to-paintcode-app-445858330997.us-east5.run.app') {
                if (event.data.type === 'resizeIframe') {
                    // Adjust the iframe's height based on the received data
                    iframe.style.height = event.data.height + 50 + 'px';
                }

              //Automatically select the color in the variant-selector dropdown
                if (event.data.type === "updatePaintCode") {
                  const paintCode = event.data.paintCode;
                  const vinSelected = event.data.vin;
                  const paintCodeWrapper = document.querySelector('.paint-code-wrapper');

                  let matchingOption = false;
                  let autoSelectedColor;

                  const variantSelector = document.getElementById('variant-selector');
                    if (variantSelector) {
                        const options = Array.from(variantSelector.options);
                        options.find(option => {
                            if(option.label.split(" ")[0] === paintCode) {
                                matchingOption = true;
                                autoSelectedColor = option.value;
                                return;
                            }
                        });
    
                        if (matchingOption) {
                            variantSelector.value = autoSelectedColor;
                            document.body.classList.remove('no-scroll-paint-swatch');
                            hideOverlay();
                            hideModal();
                            showShopifyChat();

                            // Create a new message to indicate the selected VIN
                            const vinMessage = document.createElement('div');
                            vinMessage.className = 'vin-decoder-message';
                            vinMessage.style.display = 'block';
                            vinMessage.innerHTML = `
                            <strong style="color: #444;">The paint code</strong> 
                            <span style="color: #000; font-weight: 800;">${paintCode}</span> 
                            <span style="color: #444;">has been auto-selected using the VIN: ${vinSelected}</span> 
                            `;
                        
                            // Append the message to the VIN textbox container
                            paintCodeWrapper.appendChild(vinMessage);
        
                            // Trigger the change event programmatically
                            variantSelector.dispatchEvent(new Event('change', { bubbles: true }));
                        } else {
                            boolMatchByVIN = true;

                            resortToGetPaintCodeByVin();
                            console.warn(`No matching option found for paint code: ${paintCode}`);
                        }
                    } else {
                        console.warn('Variant selector dropdown not found.');
                    }
                }

                if (event.data.type === "getPaintByVIN") {
                    resortToGetPaintCodeByVin();
                }
            }
        });

        function resortToGetPaintCodeByVin() {
            if(amountOfVINPostMessages > 0) {
                return;
            }

            const vin = event.data.vin;


            // If boolMatchByVIN is true, then it has already been set in the case that a paint code has been returned for the vin decoder but a matching
            // option has not been found for it
            if(boolMatchByVIN === false) {
                boolMatchByVIN = event.data.matchByVIN;
            }
            window.usedVinDecoder = true;

            let hiddenDiv;
            if(document.querySelector('.hidden-vin-option')) {
                hiddenDiv = document.querySelector('.hidden-vin-option');
            }
            if(document.querySelector('.hidden-vin-option-single-quality')) {
                hiddenDiv = document.querySelector('.hidden-vin-option-single-quality');
            }
            // Only display the option to select Match Paint by VIN in certain circumstances
            if(boolMatchByVIN) {
                if (hiddenDiv) {
                    // I am here!! add the if for the div
                    const div = document.querySelector('.hidden-vin-option');

                    if (hiddenDiv) {
                        const select = document.getElementById("variant-selector"); 
                        if (!select) {
                            console.error("Error: Select element not found.");
                            return;
                        }

                        // Create a new option element
                        const option = document.createElement("option");
                        option.value = hiddenDiv.dataset.value;
                        option.textContent = hiddenDiv.textContent;
                        option.setAttribute("data-price", hiddenDiv.dataset.price || "");
                        option.setAttribute("data-color", hiddenDiv.dataset.color || "");
                        option.setAttribute("data-variant-title", hiddenDiv.dataset.variantTitle || "");
                        option.setAttribute("data-product-title", hiddenDiv.dataset.productTitle || "");


                        option.classList.add("hidden-vin-option");
                        hiddenDiv.style.display = "block";

                        // Add the option back to the select
                        select.appendChild(option);

                        // Remove the div
                        hiddenDiv.remove();
                    }
                }
            }

            const variantSelector = document.getElementById('variant-selector');
            if (variantSelector) {
                const options = Array.from(variantSelector.options);
                const vinInput = document.querySelector('#vin-textbox');
                const vinTextboxForOem = document.getElementById('vin-textbox-for-oem');
                const oemVinContainer = document.querySelector('.oem-vin-container');

                
                if (oemVinContainer && oemVinContainer.style.display === "block") {
                    vinTextboxForOem.value = '';
                    oemVinContainer.style.display = "none";
                }


                if (vinInput) {
                    vinInput.value = vin;
                  }

                  options.find(option => {
                      if(option.label.startsWith("Match Paint by VIN")) {

                        const vinTextboxContainer = document.getElementById("vin-textbox-container");
                        const paintCodeWrapper = document.querySelector('.paint-code-wrapper');

                        if (vinTextboxContainer) {
                            vinTextboxContainer.style.display = "block";
                      
                            // Remove any existing message to avoid duplication
                            const existingMessage = vinTextboxContainer.querySelector('.vin-selected-message');
                            if (existingMessage) {
                              existingMessage.remove();
                            }
                      
                            // Create a new message to indicate the selected VIN
                            const vinMessage = document.createElement('div');
                            vinMessage.className = 'vin-decoder-message';
                            vinMessage.style.display = 'block';
                            vinMessage.innerHTML = `
                            <strong style="color: #444;">The VIN</strong> 
                            <span style="color: #000; font-weight: 800;">${vin}</span> 
                            <span style="color: #444;">will be attached to this order and</span> 
                            <span style="color: #444; font-weight: bold;">matched with the correct paint code</span> 
                            <span style="color: #444;">for this item.</span>
                            `;

                            window.failedVinDecode = true;
                      
                            // Append the message to the VIN textbox container
                            paintCodeWrapper.appendChild(vinMessage);
                        }                                
                        variantSelector.value = option.value;
                        document.body.classList.remove('no-scroll-paint-swatch');
                        hideOverlay();
                        hideModal();
                        showShopifyChat();

                        variantSelector.dispatchEvent(new Event('change', { bubbles: true }));

                        return;
                      }
                  });
            } else {
                console.warn('Variant selector dropdown not found.');
            }
            amountOfVINPostMessages++;
        }
    });
</script>
