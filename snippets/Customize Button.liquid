<!-- Modal trigger button -->
{% if product.title contains 'Swatch' %}

  <!-- Form for Swatches -->
  <form id="product-form" method="post" action="/cart/add">
    <!-- Variant Selector -->
    <select id="variant-selector" name="id">
      <option value="" selected disabled>Select Paint Option*</option>
      {% for variant in product.variants %}
        <option
          value="{{ variant.id }}"
          data-price="{{ variant.price }}"
          data-paint-swatch-url="{{ variant.metafields.custom.variant_swatch_url }}"
        >
          {{ variant.title }} +{{ variant.price | minus: product.price_min | money | remove: '.00' -}}
        </option>
      {% endfor %}
    </select>
    <!-- Add to Cart Button -->
      <button type="submit" class="btn full-width bold-text" id="add-to-cart" style="display: none;" disabled>Add to Cart</button>
  </form>

  <!-- Form for either customizations or add to cart on product page -->
  <form>
    {% elsif product.variants.size > 1 %}
      <button id="customize-modal-button" class="btn">Customize Now</button>
    {% else %}
    <div class="unpainted-fitment-container">
      <div id="fitment-verification-page-for-unpainted" class="popup-page active">
        <div id="model-fitmentfail-button-container">
          <div class="model-fitment-easysearch-container">
            <div class="easysearch-embed-widget-fitment"></div>
          </div>
        </div>
      </div>
      <div class="unpainted-add-to-cart-btn-container">
        <button type="submit" class="btn full-width bold-text" id="add-to-cart-for-unpainted" style="display: none;" disabled>Add to Cart</button>
      </div>
    </div>
    {% endif %}
  </form>

<!-- Modal overlay -->
<div class="customize-button-popup-dark-overlay" style="display: none;"></div>

<!-- Modal container -->

<div class="customize-popup-container" style="display: none;">
  <div class="customize-popup-overlay">
    <div class="customize-popup-modal">
    <div class="modal-exit-container">
      <button id="modal-exit" class="btn" onclick="closeModal()">&#x2715;</button>
    </div>

      <!-- Page 1: Fitment Verification -->
      <div id="fitment-verification-page" class="popup-page active">
        {% if product.variants.size == 1 and product.variants.first.title == 'Default Title' %}
          <!-- Single variant product -->
          <button id="go-to-page-2" class="add-to-cart-button-success">Add to Cart</button>
        {% else %}
          <button id="go-to-page-2" class="btn full-width bold-text" disabled>Continue</button>
        {% endif %}
      </div>

      <div id="add-to-cart-page-container">
          <div id="add-to-cart-page" class="popup-page">
            <div id="model-fitmentfail-button-container">
              <div class="model-fitment-easysearch-container">
                <div class="easysearch-embed-widget-fitment"></div>
              </div>
            </div>

            <div class="color-preview-container-for-customizations">
            {% render 'color-preview-box' %}
            </div>
            <!-- Assigns if custom paint swatch image, else defaults UNUSED-->
            <div id="variant-swatch-image">
              {% assign default_paint_swatch_image = product.metafields.custom.manufacturer_paint_match %}
              {% if variant.metafields.custom.paint_swatch_url_image != blank %}
                {% assign paint_swatch_image = variant.metafields.custom.paint_swatch_url_image %}
              {% else %}
                {% assign paint_swatch_image = default_paint_swatch_image %}
              {% endif %}
            </div>
            <br>

            <!-- Form to select paint variant by paint-code or VIN -->
            <form id="product-form" method="post" action="/cart/add">
            <div class="product-form-wrapper">
                <!-- Select Paint Option Variant Selector -->
                {% comment %} <div class="find-paint-option-link-container">
                    <a href="#" id="open-paint-code-modal">How To Find Your Paint Code</a>
                </div> {% endcomment %}
                  {% comment %} <select id="variant-selector" name="id">
                    <option value="" selected disabled>Select Paint Option*</option>
                    {% for variant in product.variants %}
                      <option
                        value="{{ variant.id }}"
                        data-price="{{ variant.price }}"
                        data-paint-swatch-url="{{ variant.metafields.custom.variant_swatch_url }}"

                      >
                        {{ variant.title }} +{{ variant.price | minus: product.price_min | money | remove: '.00' -}}
                      </option>
                    {% endfor %}
                  </select> {% endcomment %}



                {% assign meta_fields = 0 %}
                {% if product.metafields.custom.oem_product != blank %}
                  {% assign meta_fields = meta_fields | plus: 1 %}
                {% endif %}

                {% if product.metafields.custom.capa_product != blank %}
                  {% assign meta_fields = meta_fields | plus: 1 %}
                {% endif %}

                {% if product.metafields.custom.aftermarket_product != blank %}
                  {% assign meta_fields = meta_fields | plus: 1 %}
                {% endif %}

                {% if meta_fields > 1 %}
                  {% render 'CAPA-OEM-options' %}
                {% elsif product.variants.size > 1 %}
                  <!-- Variant Dropdown -->
                  <div id="variant-selector-container">
                    <label for="variant-selector" class="variant-label">Select Paint Option</label>
                    <select id="variant-selector" name="id" class="variant-dropdown">
                      <option value="" selected disabled>Paint Option</option>
                      {% for variant in product.variants %}
                        {% assign price_diff = variant.price | minus: product.price_min | money %}  
                        {% if price_diff == 0 %}
                          {{ '' }}
                        {% else %}
                          {{ '+' }}{{ price_diff | money | remove: '.00' }}
                        {% endif %}
                        <option 
                          value="{{ variant.id }}" 
                          class="variant-option"
                          data-price="{{ variant.price }}">
                          {{ variant.title }} + {{ price_diff }}
                        </option>
                      {% endfor %}
                    </select>
                    {% comment %} <select id="variant-selector" name="id">
                      <option value="" selected disabled>Select Variant</option>
                      {% for variant in product.variants %}
                          <option 
                              value="{{ variant.id }}" 
                              class="variant-option"
                              data-price="{{ variant.price }}">
                              {{ variant.title }} - {{ variant.price | money }}
                          </option>
                      {% endfor %}
                  </select> {% endcomment %}
                  </div>
                {% endif %}




                <div class="paint-or-vin">
                  <p>Or</p>
                </div>

                <!-- Select VIN Option -->
                {%- if product.metafields.custom.vin_variant_id != blank -%}
                  <!-- Text box for VIN input -->
                  <div id="vin-textbox-container" style="display: none;">
                    <input
                      type="text"
                      id="vin-textbox"
                      name="properties[VIN]"
                      placeholder="Enter your VIN"
                      maxlength="17"
                    >
                    <p id="vin-warning" style="color: #ff000f; display: none;">I, O, & Q are never used in VINs</p>
                  </div>

                  <!-- Button to select Match Paint by VIN variant -->
                  <button id="select-vin-variant" class="btn full-width bold-text" type="button">Use VIN Instead</button>  
                {% endif %}

                <!-- How to find your paint code image-->
                <div id="paint-swatch-modal" class="modal-overlay" style="display: none;">
                  <div id="close-paint-swatch" class="close-button" role="button">&times;</div>
                  <img src="{{ product.metafields.custom.manufacturer_paint_match }}" alt="Paint Swatch" id="paint-swatch-image">
                </div>  
              
              </div>
              <!-- Fixed Add to cart and price container to bottom of mobile -->
              <div class="conditional-small-screen">
                <div class="price-and-arrivesby-container">
                  <div id="price-display">$0</div>
                  {% comment %} <div id="delivery-estimate-container"></div>  {% endcomment %}
                </div>         
                <!-- Add to Cart Button for correct fitment and selected paint option-->
                <div class="add-to-cart-button-wrapper">
                  <button type="submit" class="btn full-width bold-text" id="add-to-cart" disabled>Add to Cart</button>
                </div>
              </div>
            </form>

            <!-- Custom paint swatch to populate at bottom if exists -->
            {% if variant.metafields.custom.paint_swatch_url_image != blank %}
              <div class="paint-swatch-variant-image-container">
                <img style="display: flex; padding: 20px 0 90px 0;" src="{{ variant.metafields.custom.paint_swatch_url_image }}" alt="Paint Swatch" id="paint-swatch-variant-image">
              </div>
              {% comment %} {% assign paint_swatch_image = variant.metafields.custom.paint_swatch_url_image %} {% endcomment %}
            {% else %}
            <div class="paint-swatch-variant-image-container">
              <img style="display: none;" src="https://cdn.shopify.com/s/files/1/0248/6291/6693/files/Chrysler_Dodge_Jeep_Ram-Infographic--07-15-2024_1.jpg" alt="Paint Swatch" id="paint-swatch-variant-image">
            </div>
              {% comment %} {% assign paint_swatch_image = default_paint_swatch_image %} {% endcomment %}
            {% endif %}
            {% comment %} <div class="popup-modal-content" id="dynamic-checkout-container"></div> {% endcomment %}

          </div>
      </div>

    </div>
    <div id="color-mismatch-popup" style="display: none;">
      <div class="customize-color-mismatch-popup-overlay">
        <div class="color-mismatch-container">
          <p id="mismatch-message">The color you selected is different from items already in your cart. Do you want to continue with this color?</p>
          <div id="mismatch-buttons-container">
            <button id="continue-btn">No</button>
            <button id="cancel-btn">Yes</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
      let vinSuccess = false;
      let fitmentSuccess = false;
      let paintedItem = false;

      if(parseInt('{{ product.variants.size }}') > 1) {
        paintedItem = true;
      } else {
        paintedItem = false;
      }


  // Renders the Add to Cart button on product page for non customizable products (e.g. swatch)
  document.addEventListener('DOMContentLoaded', function () {
    const variantSelector = document.getElementById('variant-selector');
    const addToCartButton = document.getElementById('add-to-cart');
    
    // let vinSuccess = false;

    variantSelector.addEventListener('change', function () {
      if (variantSelector.value) {
        addToCartButton.style.display = 'block';
        addToCartButton.disabled = false;
      } else {
        addToCartButton.style.display = 'none';
        addToCartButton.disabled = true;
      }
    });
  });
  

  // Modal overlay popup
  const overlay = document.querySelector('.customize-button-popup-dark-overlay');
  const modal = document.querySelector('.customize-popup-container');
  function closeModal() {
      document.body.style.overflow = 'auto';
      document.body.classList.remove('modal-open');
      overlay.style.display = "none";
      modal.style.display = "none";
      showShopifyChat();
      showGoogleReviews();

      {% comment %} const deliveryEstimateContainer = document.getElementById("delivery-estimate-container");
      if (deliveryEstimateContainer) {
        deliveryEstimateContainer.innerHTML = "";
      } {% endcomment %}
    
  }

  function hideShopifyChat() {
    const shopifyChat = document.getElementById('shopify-chat');
    if (shopifyChat) {
      shopifyChat.style.display = 'none';
    }
  }

// Function to show Shopify chat widget
function showShopifyChat() {
  const shopifyChat = document.getElementById('shopify-chat');
  if (shopifyChat) {
    shopifyChat.style.display = 'block';
  }
}

function hideGoogleReviews() {
  const googleReviews = document.getElementById('___ratingbadge_0');
  if (googleReviews) {
    googleReviews.style.display = 'none';
  }
}

function showGoogleReviews() {
  const googleReviews = document.getElementById('shopify-chat');
  if (googleReviews) {
    googleReviews.style.display = 'block';
  }
}

// Customization portion
  document.addEventListener('DOMContentLoaded', () => {
    const goToPage2Button = document.getElementById('go-to-page-2');
    const fitmentPage = document.getElementById('fitment-verification-page');
    const fitmentFailPage = document.getElementById('model-fitmentfail-button-container');
    const addToCartPage = document.getElementById('add-to-cart-page');
    const exitModalButton = document.getElementById('modal-exit');
    const openModalButton = document.getElementById('customize-modal-button')
    const fitmentFailButton = document.createElement('button');
    const variantSelector = document.getElementById('variant-selector');
    const form = document.getElementById('product-form');
    const addToCartButton = document.getElementById('add-to-cart');
    const paintSwatchImage = document.getElementById('paint-swatch-image');



    fitmentFailButton.id = 'fitment-fail-button';
    fitmentFailButton.textContent = 'Parts That Fit Your Vehicle';
    fitmentFailButton.onclick = () => {
        const fitmentLink = document.querySelector('.easysearch-fitment-link');
        if (fitmentLink) {
            window.location.href = fitmentLink.href; // Use the dynamic link from the fitment checker
        } else {
            alert('No link available for parts that fit your vehicle.');
        }
    };

    let fitmentSuccessfromStorage;


    const addToCartButtonForUnpaintedItems = document.getElementById("add-to-cart-for-unpainted");

    if(addToCartButtonForUnpaintedItems !== null) {
      addToCartButtonForUnpaintedItems.addEventListener("click", function () {
          form.action = `/cart/add?id=${'{{ product.variants[0].id }}'}`;
          form.submit();
    });
    }


    function checkFitmentStatusOfUnpaintedItems() {
      const easyFitmentFail = document.querySelector('.easysearch-fitment-widget .easysearch-fitment-fail');
      const easyFitmentSuccess = document.querySelector('.easysearch-fitment-widget .easysearch-fitment-icon-success');
      const fitmentLink = document.querySelector('.easysearch-fitment-link');
      const fitmentHeader = document.querySelector('.easysearch-fitment-header');


      let failChecker = 0;


      if(easyFitmentFail !== null) {
        failChecker = easyFitmentFail.offsetWidth;
      }

      if(fitmentHeader.offsetWidth === 0) {
        if (easyFitmentFail && fitmentLink && failChecker !== 0) {
          fitmentFailButton.style.display = 'block';
          addToCartButtonForUnpaintedItems.style.display = 'none';
          if (!document.getElementById('fitment-fail-button')) {
            fitmentFailPage.appendChild(fitmentFailButton);
          }
          fitmentFailButton.style.display = 'block';
          fitmentSuccess = false;
        } else if (easyFitmentSuccess && fitmentLink && failChecker === 0){
            fitmentFailButton.style.display = 'none';
            addToCartButtonForUnpaintedItems.style.display = 'block';
            addToCartButtonForUnpaintedItems.disabled = false;
            fitmentSuccess = true;
        } else {
            fitmentFailButton.style.display = 'none';
            addToCartButtonForUnpaintedItems.style.display = 'block';
            fitmentSuccess = false;
        }
      } else {
        fitmentFailButton.style.display = 'none';
        addToCartButtonForUnpaintedItems.style.display = 'block';
        addToCartButtonForUnpaintedItems.disabled = true
      }
      handleFitmentSuccessChange();
    }



    // Function to check fitment status based on the app logic
    function checkFitmentStatus() {
      goToPage2Button.style.display = 'none';
        const easyFitmentFail = document.querySelector('.easysearch-fitment-widget .easysearch-fitment-fail');
        const easyFitmentSuccess = document.querySelector('.easysearch-fitment-widget .easysearch-fitment-icon-success');
        const fitmentLink = document.querySelector('.easysearch-fitment-link'); // Get the dynamic link
        const fitmentHeader = document.querySelector('.easysearch-fitment-header');

        if(fitmentHeader.offsetWidth === 0) {
          if (easyFitmentFail && fitmentLink) {
              // Fitment failed, hide Continue button and show "Parts That Fit" button
              goToPage2Button.style.display = 'none';
              fitmentFailButton.style.display = 'block';
              if (!document.getElementById('fitment-fail-button')) {
                fitmentFailPage.appendChild(fitmentFailButton); // Append the button if it doesn't exist
              }
              fitmentFailButton.style.display = 'block';
              fitmentSuccess = false;
              handleFitmentSuccessChange();
          } else if (easyFitmentSuccess && fitmentLink){
              fitmentFailButton.style.display = 'none';
              fitmentSuccess = true;
              handleFitmentSuccessChange();
          } else {
              fitmentFailButton.style.display = 'none';
              fitmentSuccess = false;
              handleFitmentSuccessChange();
          }
          checkBothConditions(); 

        } else {
          fitmentFailButton.style.display = 'none';
          addToCartButton.disabled = true;
        }
        // localStorage.setItem('fitmentSuccess', fitmentSuccess.toString());
        // fitmentSuccessfromStorage = localStorage.getItem('fitmentSuccess') === 'true';
        // console.log('fitmentSuccessfromStorage: ', fitmentSuccessfromStorage);

    }

    // Polling function to continuously check fitment status every 500ms
    function pollFitmentStatus() {
      if(paintedItem) {
        checkFitmentStatus();
      } else {
        checkFitmentStatusOfUnpaintedItems();
      }
    }
    const fitmentCheckInterval = setInterval(pollFitmentStatus, 300);

    const variantSize = '{{ product.variants.size }}';
    const variantTitle = '{{ product.variants.first.title }}';
    const variantId = '{{ product.variants[0].id }}';
    
    function checkBothConditions() {
        const variantSelected = variantSelector.value !== ""; // Check if a variant is selected
        const selectedOptionText = variantSelector.options[variantSelector.selectedIndex].text;
        const selectedOptionCheckingForVin = selectedOptionText.includes("Match Paint by VIN");

        if (parseInt(variantSize) === 1 && variantTitle === "Default Title") {
          variantSelector.style.display = "none";
        }

        if (parseInt(variantSize) === 1 && variantTitle === "Default Title" && fitmentSuccess) {
          form.action = `/cart/add?id=${variantId}`;
          addToCartButton.style.display = 'block';
          addToCartButton.disabled = false;
        } else {
          if (variantSelected && !selectedOptionCheckingForVin && fitmentSuccess) {
              form.action = `/cart/add?id=${variantSelector.value}`;
              addToCartButton.style.display = 'block';
              addToCartButton.disabled = false;
              // loadDynamicCheckoutButton();
          } else if(selectedOptionCheckingForVin && fitmentSuccess && vinSuccess) {
            form.action = `/cart/add?id=${variantSelector.value}`;
              addToCartButton.style.display = 'block';
              addToCartButton.disabled = false;
          } else {
                form.action = '/cart/add';
                addToCartButton.style.display = 'block';
            }
        }
    }
    // Open Modal
      document.getElementById('customize-modal-button').onclick = function() {
        hideShopifyChat();
        hideGoogleReviews();
        document.body.style.overflow = 'hidden';
          overlay.style.display = 'block';
          modal.style.display = 'block';
          fitmentPage.classList.add('active');
          addToCartPage.classList.add('active');
          // paintSwatchImage.style.display = "none";
        document.body.classList.add('modal-open');

        {% comment %} const originalEstimate = document.querySelector("#shopify-block-arrivesby_delivery_estimate_GtVWkc"); {% endcomment %}
        {% comment %} const deliveryEstimateContainer = document.getElementById("delivery-estimate-container");
        if (originalEstimate && deliveryEstimateContainer) {
          // Clear any previous content in the container
          deliveryEstimateContainer.innerHTML = "";
      
          // Clone the original estimate block (deep clone to preserve event listeners and JavaScript functionality)
          const clonedEstimate = originalEstimate.cloneNode(true);
          const estimateHeight = clonedEstimate.offsetHeight; // Get the height of the cloned content

      
          // Append the cloned element to the modal container
          deliveryEstimateContainer.appendChild(clonedEstimate);
          clonedEstimate.style.display = "block";
      
          // Hide the original estimate on the page
          originalEstimate.style.display = "none";
      
          // Ensure the cloned block is visible
          deliveryEstimateContainer.style.display = "block";
        }; {% endcomment %}
      };

    // Get modal and close button elements
    const paintSwatchModal = document.getElementById('paint-swatch-modal');
    // const closePaintSwatchButton = document.getElementById('close-paint-swatch');

    // Close the modal when the "X" button is clicked
    document.getElementById('close-paint-swatch').onclick = function(event) {
      paintSwatchModal.style.display = 'none';
    }

    // Optional: Close the modal when clicking outside the image
    window.onclick = function(event) {
      if (event.target === paintSwatchModal) {
        paintSwatchModal.style.display = 'none';
      }
    }


    {% comment %} document.getElementById('open-paint-code-modal').onclick = function() {
      if(paintSwatchImage) {
        paintSwatchImage.style.display = "block";
        paintSwatchModal.style.display = 'flex';
      }
    } {% endcomment %}


    variantSelector.addEventListener('change', function() {
        const variantId = this.value;
        if (variantId && fitmentSuccess) {
            form.action = `/cart/add?id=${variantId}`;
            addToCartButton.style.display = 'block';
            addToCartButton.disabled = false;
        } else {
            form.action = '/cart/add';
            addToCartButton.disabled = true;
        }
    });

    function handleFitmentSuccessChange() {
      const variantId = this.value;
      const popupContainer = document.querySelector('.customize-popup-container'); 

      if (popupContainer && popupContainer.style.display !== 'none') {
        if (variantId && fitmentSuccess) {
            form.action = `/cart/add?id=${variantId}`;
            addToCartButton.style.display = 'block';
            addToCartButton.disabled = false;
        } else {
            form.action = '/cart/add';
            addToCartButton.disabled = true;
        }
      }
    }
});





            // This is for the Use VIN Instead button
  document.addEventListener('DOMContentLoaded', () => {
    const variantSelector = document.getElementById('variant-selector');
    const selectVinVariantButton = document.getElementById('select-vin-variant');
    const paintSwatchImage = document.getElementById('paint-swatch-image');


    // Event listener for the "Match Paint by VIN" button
    selectVinVariantButton.addEventListener('click', function() {
      // Find the option with the text "Match Paint by VIN"
      paintSwatchImage.display = "block";
      for (let i = 0; i < variantSelector.options.length; i++) {
        if (variantSelector.options[i].text.includes('Match Paint by VIN')) {
          variantSelector.selectedIndex = i;
          variantSelector.dispatchEvent(new Event('change')); // Trigger the change event
          break;
        }
      }
    });
  });






    document.addEventListener('DOMContentLoaded', function() {
        const variantSelector = document.getElementById('variant-selector');
        const vinTextBox = document.getElementById('vin-textbox');
        const addToCartButton = document.getElementById('add-to-cart');
        const useVinButton = document.getElementById('select-vin-variant'); // Ensure this ID matches

        // Function to check if the selected variant is the VIN variant
        function checkVariant() {
            const selectedOption = variantSelector.options[variantSelector.selectedIndex].text;
            if (selectedOption.includes('Match Paint by VIN')) {
                vinTextBox.style.display = 'block';
                useVinButton.style.display = 'none'; // Hide Use VIN button


            } else {
                vinTextBox.style.display = 'none';
                useVinButton.style.display = 'block'; // Show Use VIN button
                vinTextBox.value = '';
            }
        }

        // Check variant on change
        variantSelector.addEventListener('change', checkVariant);

        // Initial check in case a default selected variant is the VIN variant
        checkVariant();
        document.getElementById('vin-textbox').addEventListener('input', function(event) {
          const vinInput = event.target.value;
          const warning = document.getElementById('vin-warning');

          // Remove I, O, Q characters
          const filteredValue = vinInput.replace(/[IOQ\s:;()!@#$%^?'"&*\-_=+.`~<>{}\[\]|,\/\\]/gi, '');

          if (vinInput !== filteredValue) {
              alert("Please enter valid characters. I,O, & Q and other special characters are not included in VINs");
          } else {
              warning.style.display = 'none';
          }

          event.target.value = filteredValue;

          // Ensure VIN input is 17 characters before enabling Add to Cart
          // console.log('checking input length');
          if (vinInput.length === 17 && fitmentSuccess) {
              addToCartButton.disabled = false;
              vinSuccess = true;
              // console.log('checking input length t', vinSuccess);

          } else {
            // console.log('checking input length f');
              addToCartButton.disabled = true;
              vinSuccess = false;
          }
      });
    });






          document.addEventListener('DOMContentLoaded', function() {
            const variantSelector = document.getElementById('variant-selector');
            const vinTextBox = document.getElementById('vin-textbox-container');
            const addToCartButton = document.getElementById('add-to-cart');
            const vinInput = document.getElementById('vin-textbox');
            const vinWarning = document.getElementById('vin-warning');

            // Function to check if the selected variant is the VIN variant
            function checkVariant() {
                const selectedOption = variantSelector.options[variantSelector.selectedIndex].text;
                if (selectedOption.includes('Match Paint by VIN')) {
                    vinTextBox.style.display = 'block';
                  vinWarning.innerText = "VIN must be exactly 17 characters.";
                    vinWarning.style.display = 'block';
                    addToCartButton.disabled = true;
                } else {
                    vinTextBox.style.display = 'none';
                }
            }

            // Check variant on change
            variantSelector.addEventListener('change', checkVariant);

            // Initial check in case a default selected variant is the VIN variant
            checkVariant();

            vinInput.addEventListener('input', function(event) {
                const vin = event.target.value.toUpperCase();
                const invalidChars = /[IOQ]/;

                // Check for invalid characters
                if (invalidChars.test(vin)) {
                    vinWarning.innerText = "Characters 'I', 'O', and 'Q' are not allowed in VINs.";
                    vinWarning.style.display = 'block';
                    addToCartButton.disabled = true;
                } else if (vin.length !== 17) {
                    vinWarning.innerText = "VIN must be exactly 17 characters.";
                    vinWarning.style.display = 'block';
                    addToCartButton.disabled = true;
                } else {
                  vinSuccess = true;
                  if(fitmentSuccess) {
                    vinWarning.style.display = 'none';
                    addToCartButton.disabled = false;
                  }
                }

                // Update the VIN input value to remove invalid characters
                event.target.value = vin.replace(invalidChars, '');
            });
        });





    document.addEventListener('DOMContentLoaded', function() {
      const vinTextbox = document.getElementById('vin-textbox');
      const useVinButton = document.getElementById('select-vin-variant');

      // Function to toggle the visibility of the Use VIN button
      function toggleVinButton() {
          if (vinTextbox.style.display === 'block') {
              useVinButton.style.display = 'none';
            addToCartButton.disabled = true;
          } else {
              useVinButton.style.display = 'block';
          }
      }

      // Initially check visibility
      toggleVinButton();

      // Example event listener (replace with your actual trigger)
      // Assuming you show the VIN textbox on a button click
      const vinOption = document.getElementById('vin-option'); // Replace with your VIN option ID
      vinOption.addEventListener('change', function() {
          if (this.checked) { // Check if the VIN option is selected
              vinTextbox.style.display = 'block'; // Show VIN textbox
            document.getElementById('vin-textbox').focus();
          } else {
              vinTextbox.style.display = 'none'; // Hide VIN textbox
          }
          toggleVinButton(); // Call to update the Use VIN button visibility
      });
  });




       document.addEventListener('DOMContentLoaded', function() {
        const variantSelector = document.querySelector('select[name="id"]');
        const paintSwatchVariantImage = document.getElementById('paint-swatch-variant-image');

        variantSelector.addEventListener('change', function() {
          const selectedVariant = this.options[this.selectedIndex];
          // Get the variant metafield URL from a data attribute
          const variantPaintSwatchUrl = selectedVariant.dataset.paintSwatchUrl;

          if (variantPaintSwatchUrl) {
            paintSwatchVariantImage.src = variantPaintSwatchUrl;
          } else {
            paintSwatchVariantImage.src = "{{ product.metafields.custom.manufacturer_paint_match }}";
          }
        });
      });

      const imageUrl = paintSwatchUrl || productImageUrl; // fallback to product image
      const imageElement = document.querySelector('#your-image-element'); // replace with your actual image element ID or class

