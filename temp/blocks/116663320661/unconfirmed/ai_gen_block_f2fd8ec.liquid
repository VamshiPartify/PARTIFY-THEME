{% doc %}
  @prompt
    Add a form block with ID 488634 to the page, ensuring it's properly styled and functional

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-form-block-{{ ai_gen_id }} {
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-form-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    margin-bottom: 20px;
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-form-description-{{ ai_gen_id }} {
    margin-bottom: 25px;
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-form-fields-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 15px;
    margin-bottom: 20px;
  }

  .ai-form-field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
  }

  .ai-form-label-{{ ai_gen_id }} {
    margin-bottom: 5px;
    font-weight: 500;
    color: {{ block.settings.text_color }};
  }

  .ai-form-input-{{ ai_gen_id }},
  .ai-form-textarea-{{ ai_gen_id }} {
    padding: 12px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    background-color: {{ block.settings.input_background_color }};
    color: {{ block.settings.input_text_color }};
  }

  .ai-form-textarea-{{ ai_gen_id }} {
    min-height: 100px;
    resize: vertical;
  }

  .ai-form-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    cursor: pointer;
    transition: background-color 0.3s;
    text-align: center;
  }

  .ai-form-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-form-button-wrapper-{{ ai_gen_id }} {
    text-align: {{ block.settings.button_alignment }};
  }

  .ai-form-success-{{ ai_gen_id }} {
    padding: 15px;
    background-color: {{ block.settings.success_background_color }};
    color: {{ block.settings.success_text_color }};
    border-radius: 4px;
    margin-top: 20px;
  }

  .ai-form-error-{{ ai_gen_id }} {
    padding: 15px;
    background-color: {{ block.settings.error_background_color }};
    color: {{ block.settings.error_text_color }};
    border-radius: 4px;
    margin-top: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-form-block-{{ ai_gen_id }} {
      padding: {{ block.settings.padding | divided_by: 1.5 }}px;
    }
    
    .ai-form-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | minus: 4 }}px;
    }
  }
{% endstyle %}

<div class="ai-form-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-form-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  {% if block.settings.description != blank %}
    <div class="ai-form-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
  {% endif %}

  {%- form 'contact', id: '488634' -%}
    <div class="ai-form-fields-{{ ai_gen_id }}">
      {% if block.settings.show_name %}
        <div class="ai-form-field-{{ ai_gen_id }}">
          <label for="ContactFormName-{{ ai_gen_id }}" class="ai-form-label-{{ ai_gen_id }}">{{ block.settings.name_label }}</label>
          <input 
            type="text" 
            id="ContactFormName-{{ ai_gen_id }}" 
            name="contact[name]" 
            class="ai-form-input-{{ ai_gen_id }}" 
            value="{% if form.name %}{{ form.name }}{% endif %}"
            {% if block.settings.name_required %}required{% endif %}
          >
        </div>
      {% endif %}

      {% if block.settings.show_email %}
        <div class="ai-form-field-{{ ai_gen_id }}">
          <label for="ContactFormEmail-{{ ai_gen_id }}" class="ai-form-label-{{ ai_gen_id }}">{{ block.settings.email_label }}</label>
          <input 
            type="email" 
            id="ContactFormEmail-{{ ai_gen_id }}" 
            name="contact[email]" 
            class="ai-form-input-{{ ai_gen_id }}" 
            value="{% if form.email %}{{ form.email }}{% endif %}" 
            spellcheck="false" 
            autocomplete="email" 
            autocorrect="off" 
            autocapitalize="off"
            {% if block.settings.email_required %}required{% endif %}
          >
        </div>
      {% endif %}

      {% if block.settings.show_phone %}
        <div class="ai-form-field-{{ ai_gen_id }}">
          <label for="ContactFormPhone-{{ ai_gen_id }}" class="ai-form-label-{{ ai_gen_id }}">{{ block.settings.phone_label }}</label>
          <input 
            type="tel" 
            id="ContactFormPhone-{{ ai_gen_id }}" 
            name="contact[phone]" 
            class="ai-form-input-{{ ai_gen_id }}" 
            value="{% if form.phone %}{{ form.phone }}{% endif %}" 
            pattern="[0-9\-]*"
            {% if block.settings.phone_required %}required{% endif %}
          >
        </div>
      {% endif %}

      {% if block.settings.show_subject %}
        <div class="ai-form-field-{{ ai_gen_id }}">
          <label for="ContactFormSubject-{{ ai_gen_id }}" class="ai-form-label-{{ ai_gen_id }}">{{ block.settings.subject_label }}</label>
          <input 
            type="text" 
            id="ContactFormSubject-{{ ai_gen_id }}" 
            name="contact[subject]" 
            class="ai-form-input-{{ ai_gen_id }}" 
            value="{% if form.subject %}{{ form.subject }}{% endif %}"
            {% if block.settings.subject_required %}required{% endif %}
          >
        </div>
      {% endif %}

      {% if block.settings.show_message %}
        <div class="ai-form-field-{{ ai_gen_id }}">
          <label for="ContactFormMessage-{{ ai_gen_id }}" class="ai-form-label-{{ ai_gen_id }}">{{ block.settings.message_label }}</label>
          <textarea 
            id="ContactFormMessage-{{ ai_gen_id }}" 
            name="contact[body]" 
            class="ai-form-textarea-{{ ai_gen_id }}"
            {% if block.settings.message_required %}required{% endif %}
          >{% if form.body %}{{ form.body }}{% endif %}</textarea>
        </div>
      {% endif %}
    </div>

    <div class="ai-form-button-wrapper-{{ ai_gen_id }}">
      <button type="submit" class="ai-form-button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </button>
    </div>

    {% if form.posted_successfully? %}
      <div class="ai-form-success-{{ ai_gen_id }}">
        {{ block.settings.success_message }}
      </div>
    {% endif %}

    {% if form.errors %}
      <div class="ai-form-error-{{ ai_gen_id }}">
        {{ block.settings.error_message }}
        <ul>
          {% for field in form.errors %}
            <li>{{ field | capitalize }}: {{ form.errors.messages[field] }}</li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}
  {%- endform -%}
</div>

